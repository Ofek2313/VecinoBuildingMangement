                    <TextBlock  Style="{StaticResource navText}">
                    <Hyperlink TextDecorations="None" Foreground="#64748b" x:Name="HyperlinkFinance" Click="HyperlinkFinance_Click" >Finance</Hyperlink>
                </TextBlock>
                </StackPanel>
            </Border>
