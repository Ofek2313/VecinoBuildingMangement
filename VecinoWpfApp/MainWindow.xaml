                    <TextBlock Style="{StaticResource navText}">
                        <Hyperlink TextDecorations="None" Foreground="#64748b"  x:Name="HyperlinkDashboard" Click="HyperlinkDashboard_Click">Dashboard</Hyperlink>

                    </TextBlock>
                </StackPanel>
            </Border>
