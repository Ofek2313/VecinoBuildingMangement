            <Border Style="{StaticResource navItem}" x:Name="resNav">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="20" Height="20" Margin="0,0,10,0">
                        <Path Fill="#64748b" StrokeLineJoin="Round">
