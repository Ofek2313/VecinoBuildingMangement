<UserControl x:Class="VecinoWpfApp.UserControls.Finance"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VecinoWpfApp.UserControls"
             xmlns:conv ="clr-namespace:VecinoWpfApp"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1670">

    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f8fafc" Offset="0"/>
            <GradientStop Color="#f0fdf4" Offset="0.5"/>
            <GradientStop Color="#ecfdf5" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Resources>
        <conv:UrlConverter x:Key="urlConvertor"></conv:UrlConverter>
        <conv:FeeStatusStyleConverter x:Key="feeStatusStyleConverter"></conv:FeeStatusStyleConverter>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="3" ShadowDepth="1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#14b8a6" Offset="0"/>
                        <GradientStop Color="#22c55e" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.08" BlurRadius="4" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#f1f5f9"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RemindButton" TargetType="Button">
            <Setter Property="Background" Value="#fff4e6"/>
            <Setter Property="Foreground" Value="#ff8c42"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Badge" TargetType="Border">
           
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style x:Key="PaidBadge" TargetType="Border">
            <Setter Property="Background" Value="#dcfce7"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style x:Key="UnpaidBadge" TargetType="Border">
            <Setter Property="Background" Value="#fee2e2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style x:Key="OverdueBadge" TargetType="Border">
            <Setter Property="Background" Value="#fff4e6"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style x:Key="AvatarBorder" TargetType="Border">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="CornerRadius" Value="21"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Background" Value="#e2e8f0"/>
        </Style>

    </UserControl.Resources>

    <Canvas>

        <!-- Page Title -->
        <TextBlock Canvas.Left="82" Canvas.Top="28"
                   Text="Finance Overview"
                   FontFamily="Segoe UI" FontSize="27" FontWeight="SemiBold"
                   Foreground="#1e293b"/>
        <TextBlock Canvas.Left="82" Canvas.Top="69"
                   Text="Track rent payments, outstanding balances, and fee collection"
                   FontFamily="Segoe UI" FontSize="15"
                   Foreground="#64748b"/>

        <!-- Top Action Buttons -->
        <Button Canvas.Left="1398" Canvas.Top="40"
                Content="+ Add Fee"
                Style="{StaticResource PrimaryButton}"
                Height="42" Width="130" Click="AddFeeButton_Click"
               />

        <Button Canvas.Left="1240" Canvas.Top="40"
                Content="Export Report"
                Style="{StaticResource SecondaryButton}"
                Height="42" Width="140"
                />

        <!-- ======= STAT CARDS ======= -->

        <!-- Total Collected -->
        <Border Canvas.Left="82" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#14b8a6" Offset="0"/>
                            <GradientStop Color="#22c55e" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="💰" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalCollected,StringFormat={}{0}₪}" FontSize="24" FontWeight="Bold" Foreground="#0f172a" FontFamily="Segoe UI"/>
                    <TextBlock Text="Total Collected" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Outstanding -->
        <Border Canvas.Left="330" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0" Background="#fee2e2">
                    <TextBlock Text="⚠️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Outstanding,StringFormat={}{0}₪}" FontSize="24" FontWeight="Bold" Foreground="#e11d48" FontFamily="Segoe UI"/>
                    <TextBlock Text="Outstanding" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Residents Paid -->
        <Border Canvas.Left="578" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0" Background="#dcfce7">
                    <TextBlock Text="✅" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalPaid}" FontSize="24" FontWeight="Bold" Foreground="#16a34a" FontFamily="Segoe UI"/>
                    <TextBlock Text="Residents Paid" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Residents Unpaid -->
        <Border Canvas.Left="826" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0" Background="#fee2e2">
                    <TextBlock Text="🚫" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalUnPaid}" FontSize="24" FontWeight="Bold" Foreground="#e11d48" FontFamily="Segoe UI"/>
                    <TextBlock Text="Residents Unpaid" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Collection Rate -->
        <Border Canvas.Left="1074" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0" Background="#e0f2fe">
                    <TextBlock Text="📊" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding CollectionRate,StringFormat={}{0}%}" FontSize="24" FontWeight="Bold" Foreground="#0284c7" FontFamily="Segoe UI"/>
                    <TextBlock Text="Collection Rate" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- This Month -->
        <Border Canvas.Left="1322" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0" Background="#f5f3ff">
                    <TextBlock Text="📅" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="8,750₪" FontSize="24" FontWeight="Bold" Foreground="#7c3aed" FontFamily="Segoe UI"/>
                    <TextBlock Text="This Month" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

       

        <!-- ======= RESIDENT PAYMENT TABLE ======= -->
        <Border Canvas.Left="82" Canvas.Top="234 " Width="920" Height="700" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="54"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0" Background="#f8fafc" CornerRadius="16,16,0,0" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="RESIDENT" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center" Margin="54,0,0,0"/>
                        <TextBlock Grid.Column="1" Text="UNIT"     FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="AMOUNT"   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="STATUS"   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="ACTIONS"  FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    </Grid>
                </Border>
                
                <!-- Static Row -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ListView x:Name="listViewFees" HorizontalContentAlignment="Stretch" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="24,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Style="{StaticResource AvatarBorder}">
                                                    <Image Source="{Binding ResidentImage,Converter={StaticResource urlConvertor}}"></Image>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ResidentName}" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#0f172a"/>
                                                    <TextBlock  FontFamily="Segoe UI" FontSize="11" Foreground="#94a3b8">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Path=Fee.FeeDueDate, StringFormat=Due Date {0}}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Fee.IsPaid}" Value="True">
                                                                        <Setter Property="Text" Value="{Binding Path=Fee.PaymentDate, StringFormat=Payment Date {0}}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="101" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#1e293b" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Fee.FeeAmount,StringFormat={}{0}₪}" 
                                                       FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" 
                                                       Foreground="#0f172a"/>
                                                    <TextBlock Text="{Binding Fee.FeeTitle}" 
                                                       FontFamily="Segoe UI" FontSize="11" 
                                                       Foreground="#94a3b8"/>
                                            </StackPanel>
                                            <Border Grid.Column="3" Background="{Binding Fee.IsPaid,Converter={StaticResource feeStatusStyleConverter},ConverterParameter=Badge}" Style="{StaticResource Badge}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Fee.IsPaid,Converter={StaticResource feeStatusStyleConverter},ConverterParameter=Label}" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="{Binding Fee.IsPaid,Converter={StaticResource feeStatusStyleConverter},ConverterParameter=Text}"/>
                                            </Border>
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Content="Remind" Style="{StaticResource RemindButton}" Height="30" Margin="0,0,6,0" Click="SendReminder_Click" />
                                                <Button x:Name="ViewFeeButton" Content="View" Style="{StaticResource SecondaryButton}" Height="30" Click="ViewFeeButton_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                      
                        


                       

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

      

        <!-- ======= RECENT TRANSACTIONS CARD ======= -->
        <Border Canvas.Left="1022" Canvas.Top="234" Width="572" Height="700" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#f8fafc" CornerRadius="16,16,0,0" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                    <TextBlock Text="Recent Transactions" FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold" Foreground="#1e293b" VerticalAlignment="Center" Margin="22,0,0,0"/>
                </Border>

                <StackPanel Grid.Row="1">
                    <ListView x:Name="ListViewTransaction" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="22,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17" Margin="0,0,10,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#14b8a6" Offset="0"/>
                                                    <GradientStop Color="#22c55e" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="✓" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ResidentName}" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#1e293b"/>
                                            <TextBlock Text="{Binding Fee.FeeTitle}" FontFamily="Segoe UI" FontSize="11" Foreground="#94a3b8"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Fee.FeeAmount,StringFormat= +{0}₪}" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#16a34a" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Fee.PaymentDate}" FontFamily="Segoe UI" FontSize="11" Foreground="#94a3b8" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Grid>
        </Border>

    </Canvas>
</UserControl>