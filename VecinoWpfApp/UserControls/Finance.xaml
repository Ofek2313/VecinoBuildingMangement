<UserControl x:Class="VecinoWpfApp.UserControls.Finance"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VecinoWpfApp.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1670">

    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f8fafc" Offset="0"/>
            <GradientStop Color="#f0fdf4" Offset="0.5"/>
            <GradientStop Color="#ecfdf5" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Resources>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="3" ShadowDepth="1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#14b8a6" Offset="0"/>
                        <GradientStop Color="#22c55e" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.08" BlurRadius="4" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#f1f5f9"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RemindButton" TargetType="Button">
            <Setter Property="Background" Value="#fff4e6"/>
            <Setter Property="Foreground" Value="#ff8c42"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PaidBadge" TargetType="Border">
            <Setter Property="Background" Value="#dcfce7"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style x:Key="UnpaidBadge" TargetType="Border">
            <Setter Property="Background" Value="#fee2e2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style x:Key="OverdueBadge" TargetType="Border">
            <Setter Property="Background" Value="#fff4e6"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style x:Key="AvatarBorder" TargetType="Border">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="CornerRadius" Value="21"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Background" Value="#e2e8f0"/>
        </Style>

    </UserControl.Resources>

    <Canvas>

        <!-- Page Title -->
        <TextBlock Canvas.Left="82" Canvas.Top="28"
                   Text="Finance Overview"
                   FontFamily="Segoe UI" FontSize="27" FontWeight="SemiBold"
                   Foreground="#1e293b"/>
        <TextBlock Canvas.Left="82" Canvas.Top="69"
                   Text="Track rent payments, outstanding balances, and fee collection"
                   FontFamily="Segoe UI" FontSize="15"
                   Foreground="#64748b"/>

        <!-- Top Action Buttons -->
        <Button Canvas.Left="1398" Canvas.Top="40"
                Content="+ Add Fee"
                Style="{StaticResource PrimaryButton}"
                Height="42" Width="130"
               />

        <Button Canvas.Left="1240" Canvas.Top="40"
                Content="Export Report"
                Style="{StaticResource SecondaryButton}"
                Height="42" Width="140"
                />

        <!-- ======= STAT CARDS ======= -->

        <!-- Total Collected -->
        <Border Canvas.Left="82" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#14b8a6" Offset="0"/>
                            <GradientStop Color="#22c55e" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="💰" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="12,450₪" FontSize="24" FontWeight="Bold" Foreground="#0f172a" FontFamily="Segoe UI"/>
                    <TextBlock Text="Total Collected" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Outstanding -->
        <Border Canvas.Left="330" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0" Background="#fee2e2">
                    <TextBlock Text="⚠️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="3,200₪" FontSize="24" FontWeight="Bold" Foreground="#e11d48" FontFamily="Segoe UI"/>
                    <TextBlock Text="Outstanding" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Residents Paid -->
        <Border Canvas.Left="578" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0" Background="#dcfce7">
                    <TextBlock Text="✅" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="18" FontSize="24" FontWeight="Bold" Foreground="#16a34a" FontFamily="Segoe UI"/>
                    <TextBlock Text="Residents Paid" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Residents Unpaid -->
        <Border Canvas.Left="826" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0" Background="#fee2e2">
                    <TextBlock Text="🚫" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="6" FontSize="24" FontWeight="Bold" Foreground="#e11d48" FontFamily="Segoe UI"/>
                    <TextBlock Text="Residents Unpaid" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Collection Rate -->
        <Border Canvas.Left="1074" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0" Background="#e0f2fe">
                    <TextBlock Text="📊" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="75%" FontSize="24" FontWeight="Bold" Foreground="#0284c7" FontFamily="Segoe UI"/>
                    <TextBlock Text="Collection Rate" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- This Month -->
        <Border Canvas.Left="1322" Canvas.Top="118" Width="230" Height="96" Style="{StaticResource CardBorder}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <Border Width="46" Height="46" CornerRadius="12" Margin="0,0,14,0" Background="#f5f3ff">
                    <TextBlock Text="📅" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="8,750₪" FontSize="24" FontWeight="Bold" Foreground="#7c3aed" FontFamily="Segoe UI"/>
                    <TextBlock Text="This Month" FontSize="11" Foreground="#64748b" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ======= PROGRESS BAR ======= -->
        <Border Canvas.Left="82" Canvas.Top="238" Width="1512" Height="66" Style="{StaticResource CardBorder}">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Monthly Collection Progress" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#1e293b"/>
                    <TextBlock Text="18 of 24 residents paid this month" FontFamily="Segoe UI" FontSize="11" Foreground="#64748b"/>
                </StackPanel>
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Border Height="12" Background="#f1f5f9" CornerRadius="6"/>
                    <!-- 75% fill — set Width in code-behind relative to actual track width, or use a converter -->
                    <Border Height="12" CornerRadius="6" HorizontalAlignment="Left" Width="840">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#14b8a6" Offset="0"/>
                                <GradientStop Color="#22c55e" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
                <TextBlock Grid.Column="2" Text="75%" FontFamily="Segoe UI" FontSize="18" FontWeight="Bold" Foreground="#16a34a" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </Grid>
        </Border>

        <!-- ======= RESIDENT PAYMENT TABLE ======= -->
        <Border Canvas.Left="82" Canvas.Top="328" Width="920" Height="700" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="54"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0" Background="#f8fafc" CornerRadius="16,16,0,0" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="RESIDENT" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center" Margin="54,0,0,0"/>
                        <TextBlock Grid.Column="1" Text="UNIT"     FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="AMOUNT"   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="STATUS"   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="ACTIONS"  FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    </Grid>
                </Border>

                <!-- Static Row -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Row 1 — Paid -->
                        <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="24,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource AvatarBorder}">
                                        <TextBlock Text="SC" FontSize="15" FontWeight="Bold" Foreground="#64748b" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Sarah Cohen" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#0f172a"/>
                                        <TextBlock Text="Paid 12/03/2026" FontFamily="Segoe UI" FontSize="11" Foreground="#94a3b8"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="101" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#1e293b" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="500₪" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#0f172a" VerticalAlignment="Center"/>
                                <Border Grid.Column="3" Style="{StaticResource PaidBadge}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="Paid" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="#16a34a"/>
                                </Border>
                                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Remind" Style="{StaticResource RemindButton}" Height="30" Margin="0,0,6,0"/>
                                    <Button Content="View" Style="{StaticResource SecondaryButton}" Height="30" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Row 2 — Unpaid -->
                        <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="24,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource AvatarBorder}">
                                        <TextBlock Text="DL" FontSize="15" FontWeight="Bold" Foreground="#64748b" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="David Levi" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#0f172a"/>
                                        <TextBlock Text="Due 01/03/2026" FontFamily="Segoe UI" FontSize="11" Foreground="#94a3b8"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="102" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#1e293b" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="500₪" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#0f172a" VerticalAlignment="Center"/>
                                <Border Grid.Column="3" Style="{StaticResource UnpaidBadge}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="Unpaid" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="#e11d48"/>
                                </Border>
                                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Remind" Style="{StaticResource RemindButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="View" Style="{StaticResource SecondaryButton}" Height="30" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Row 3 — Overdue -->
                        <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="24,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource AvatarBorder}">
                                        <TextBlock Text="AB" FontSize="15" FontWeight="Bold" Foreground="#64748b" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Avi Ben-David" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#0f172a"/>
                                        <TextBlock Text="Overdue since 01/02" FontFamily="Segoe UI" FontSize="11" Foreground="#94a3b8"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="202" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#1e293b" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="500₪" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#0f172a" VerticalAlignment="Center"/>
                                <Border Grid.Column="3" Style="{StaticResource OverdueBadge}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="Overdue" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="#ff8c42"/>
                                </Border>
                                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Remind" Style="{StaticResource RemindButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="View" Style="{StaticResource SecondaryButton}" Height="30" />
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ======= FEE BREAKDOWN CARD ======= -->
        <Border Canvas.Left="1022" Canvas.Top="328" Width="572" Height="336" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#f8fafc" CornerRadius="16,16,0,0" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                    <Grid Margin="22,0">
                        <TextBlock Text="Fee Breakdown" FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold" Foreground="#1e293b" VerticalAlignment="Center"/>
                        <Button Content="Manage Fees" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Height="32" />
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,4,0,0">

                    <!-- Fee Row 1 -->
                    <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="22,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="5" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#14b8a6" Offset="0"/>
                                        <GradientStop Color="#22c55e" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Monthly Fee" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#1e293b"/>
                                <TextBlock Text="Regular monthly dues" FontFamily="Segoe UI" FontSize="11" Foreground="#94a3b8"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="500₪" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#0f172a" VerticalAlignment="Center" Margin="16,0"/>
                            <TextBlock Grid.Column="3" Text="18/24 collected" FontFamily="Segoe UI" FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Fee Row 2 -->
                    <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="22,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="5" Margin="0,0,10,0" Background="#fee2e2"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Repair Fee" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#1e293b"/>
                                <TextBlock Text="Building maintenance" FontFamily="Segoe UI" FontSize="11" Foreground="#94a3b8"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="250₪" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#0f172a" VerticalAlignment="Center" Margin="16,0"/>
                            <TextBlock Grid.Column="3" Text="12/24 collected" FontFamily="Segoe UI" FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Fee Row 3 -->
                    <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="22,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="5" Margin="0,0,10,0" Background="#e0f2fe"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Parking Fee" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#1e293b"/>
                                <TextBlock Text="Monthly parking" FontFamily="Segoe UI" FontSize="11" Foreground="#94a3b8"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="150₪" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="#0f172a" VerticalAlignment="Center" Margin="16,0"/>
                            <TextBlock Grid.Column="3" Text="10/24 collected" FontFamily="Segoe UI" FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ======= RECENT TRANSACTIONS CARD ======= -->
        <Border Canvas.Left="1022" Canvas.Top="678" Width="572" Height="350" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#f8fafc" CornerRadius="16,16,0,0" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                    <TextBlock Text="Recent Transactions" FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold" Foreground="#1e293b" VerticalAlignment="Center" Margin="22,0,0,0"/>
                </Border>

                <StackPanel Grid.Row="1">

                    <!-- Transaction 1 -->
                    <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="22,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#14b8a6" Offset="0"/>
                                        <GradientStop Color="#22c55e" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="✓" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
