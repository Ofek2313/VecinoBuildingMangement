<UserControl x:Class="VecinoWpfApp.UserControls.Requests"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VecinoWpfApp.UserControls"
             xmlns:conv="clr-namespace:VecinoWpfApp"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1645" d:Background="White">

    <UserControl.Resources>

        <conv:RequestStatusConverter x:Key="requestStatusConverter"/>
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="CornerRadius"   Value="10"/>
            <Setter Property="Padding"        Value="10,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <!-- ===== STATUS BADGE STYLES ===== -->
        <Style x:Key="PendingBadge" TargetType="Border">
            <Setter Property="Background"     Value="#fff0e0"/>
            <Setter Property="CornerRadius"   Value="10"/>
            <Setter Property="Padding"        Value="10,4"/>
            <Setter Property="BorderBrush"    Value="#ffd4a8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="InProgressBadge" TargetType="Border">
            <Setter Property="Background"     Value="#e8f0fe"/>
            <Setter Property="CornerRadius"   Value="10"/>
            <Setter Property="Padding"        Value="10,4"/>
            <Setter Property="BorderBrush"    Value="#c5d8f8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="CompletedBadge" TargetType="Border">
            <Setter Property="Background"     Value="#e8f5e9"/>
            <Setter Property="CornerRadius"   Value="10"/>
            <Setter Property="Padding"        Value="10,4"/>
            <Setter Property="BorderBrush"    Value="#b8dfc0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <!-- ===== STAT CARD ===== -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="16,14"/>
            <Setter Property="BorderBrush"     Value="#ffd4a8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="StatIcon" TargetType="Border">
            <Setter Property="Width"        Value="40"/>
            <Setter Property="Height"       Value="40"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin"       Value="0,0,12,0"/>
        </Style>

        <!-- ===== FILTER PILL ===== -->
        <Style x:Key="FilterPill" TargetType="Button">
            <Setter Property="Background"   Value="#fff8f0"/>
            <Setter Property="Foreground"   Value="#bf7030"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="12,5"/>
            <Setter Property="Margin"       Value="0,0,6,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                BorderBrush="#ffd4a8"
                                BorderThickness="1.5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ffe8cc"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterPillActive" TargetType="Button" BasedOn="{StaticResource FilterPill}">
            <Setter Property="Background" Value="#ff8c30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                BorderBrush="#ff8c30"
                                BorderThickness="1.5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e07020"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== ACTION BUTTON (orange) ===== -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background"   Value="#ff8c30"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="14,6"/>
            <Setter Property="Margin"       Value="0,0,8,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding Background}"
                                BorderThickness="1.5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e07020"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== ACTION BUTTON (blue – for In Progress) ===== -->
        <Style x:Key="ActionButtonBlue" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#4a7ee8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3a6ed8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== SECONDARY BUTTON ===== -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#fff8f0"/>
            <Setter Property="Foreground"   Value="#bf7030"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="14,6"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="#ffd4a8"
                                BorderThickness="1.5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#fff0e0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== LISTVIEW ITEM – removes default highlight chrome ===== -->
        <Style x:Key="CardItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"        Value="0"/>
            <Setter Property="Margin"         Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ===================================================
         PAGE BACKGROUND
    =================================================== -->
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#fdf6f0" Offset="0"/>
            <GradientStop Color="#fff4e6" Offset="0.5"/>
            <GradientStop Color="#fff8ed" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <!-- ===================================================
         MAIN LAYOUT
    =================================================== -->
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header        -->
            <RowDefinition Height="Auto"/>
            <!-- Stat cards    -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar       -->
            <RowDefinition Height="*"/>
            <!-- Cards list    -->
        </Grid.RowDefinitions>

        <!-- ── ROW 0 : PAGE HEADER ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Service Requests"
                       FontSize="28" FontWeight="Bold"
                       FontFamily="Segoe UI"
                       Foreground="#1a1a1a"/>
            <TextBlock Text="Track and manage all maintenance and service submissions"
                       FontSize="13" FontFamily="Segoe UI"
                       Foreground="#bf7030"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── ROW 1 : STAT CARDS ── -->
        <Grid Grid.Row="1" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Pending -->
            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StatIcon}" Background="#fff0e0">
                        <TextBlock Text="⏱" FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PENDING"
                                   FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="#bf7030"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Pending}"
                                   FontSize="26" FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   Foreground="#e07020"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- In Progress -->
            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StatIcon}" Background="#e8f0fe">
                        <TextBlock Text="⚙" FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="IN PROGRESS"
                                   FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="#2d59b5"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding InProgress}"
                                   FontSize="26" FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   Foreground="#4a7ee8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Completed -->
            <Border Grid.Column="4" Style="{StaticResource StatCard}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StatIcon}" Background="#e8f5e9">
                        <TextBlock Text="✓" FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#3a9e4e"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="COMPLETED"
                                   FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="#2e7d3b"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Completed}"
                                   FontSize="26" FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   Foreground="#3a9e4e"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── ROW 2 : TOOLBAR ── -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="All Requests"
                       FontSize="15" FontWeight="SemiBold"
                       FontFamily="Segoe UI"
                       Foreground="#1a1a1a"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="All"         Style="{StaticResource FilterPillActive}"/>
                <Button Content="Pending"     Style="{StaticResource FilterPill}"/>
                <Button Content="In Progress" Style="{StaticResource FilterPill}"/>
                <Button Content="Completed"   Style="{StaticResource FilterPill}"/>
            </StackPanel>
        </Grid>

        <!-- ── ROW 3 : CARDS LIST ── -->
        <ListView x:Name="listViewRequests"
                  Grid.Row="3"
                  ItemContainerStyle="{StaticResource CardItemStyle}"
                  Background="Transparent"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  HorizontalContentAlignment="Stretch">

            <ListView.ItemTemplate>
                <DataTemplate>

                    <!--
                        The card shell. BorderThickness left=4 gives the coloured accent.
                        We use a MultiBinding + converter on BorderBrush to pick the
                        right accent colour from RequestStatus.
                        Fallback shown below uses a single orange for all – swap
                        BorderBrush binding for your StatusToAccentBrushConverter if needed.
                    -->
                    <Border Background="White"
                            CornerRadius="14"
                            BorderThickness="4,1.5,1.5,1.5"
                            Margin="0,0,0,10"
                            Padding="18,16">

                        <Border.BorderBrush>
                            <!-- Reuse your existing converter; return a SolidColorBrush -->
                            <SolidColorBrush Color="#ff8c30"/>
                        </Border.BorderBrush>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Title row   -->
                                <RowDefinition Height="10"/>
                                <!-- Spacer      -->
                                <RowDefinition Height="Auto"/>
                                <!-- Meta row    -->
                                <RowDefinition Height="Auto"/>
                                <!-- Divider     -->
                                <RowDefinition Height="Auto"/>
                                <!-- Action row  -->
                            </Grid.RowDefinitions>

                            <!-- ── TITLE ROW ── -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ServiceRequest.RequestTitle}"
                                               FontSize="15" FontWeight="SemiBold"
                                               FontFamily="Segoe UI"
                                               Foreground="#1a1a1a"
                                               Margin="0,0,0,4"/>
                                    <!-- Category dot + label -->
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7"
                                                 Fill="#ff8c30"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding RequestTypeName}"
                                                   FontSize="12" FontFamily="Segoe UI"
                                                   Foreground="#bf7030"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Status badge (right-aligned) -->
                                <Border Grid.Column="1"
                                       Style="{StaticResource Badge}" Background="{Binding ServiceRequest.RequestStatus,Converter={StaticResource requestStatusConverter},ConverterParameter=background}"
                                               >
                                    <TextBlock Text="{Binding ServiceRequest.RequestStatus}"
                                               Foreground="{Binding ServiceRequest.RequestStatus,Converter={StaticResource requestStatusConverter},ConverterParameter=text}"
                                               FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </Grid>

                            <!-- ── META ROW ── -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">

                                <!-- Avatar + Name + Unit -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                                    <Border Width="28" Height="28"
                                            CornerRadius="14"
                                            Background="#fff0e0"
                                            BorderBrush="#ffd4a8"
                                            BorderThickness="1.5"
                                            Margin="0,0,8,0">
                                        <TextBlock Text="{Binding ResidentInitials}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI"
                                                   Foreground="#bf5000"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ResidentName}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI"
                                                   Foreground="#444"/>
                                        <TextBlock Text="Unit: 30"
                                                   FontSize="11" FontFamily="Segoe UI"
                                                   Foreground="#aaa"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Separator dot -->
                                <Ellipse Width="4" Height="4" Fill="#ffd4a8"
                                         VerticalAlignment="Center" Margin="0,0,20,0"/>

                                <!-- Date -->
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,20,0">
                                    <TextBlock Text="📅 " FontSize="12" Foreground="#ccc"/>
                                    <TextBlock Text="{Binding ServiceRequest.RequestDate}"
                                               FontSize="12" FontFamily="Segoe UI"
                                               Foreground="#888"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                               

                                <!-- Priority dot + label -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding PriorityColor}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Priority}"
                                               FontSize="12" FontFamily="Segoe UI"
                                               Foreground="#888"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                            </StackPanel>

                            <!-- ── DIVIDER ── -->
                            <Border Grid.Row="3"
                                    BorderBrush="#fff0e0"
                                    BorderThickness="0,1,0,0"
                                    Margin="0,12,0,12"/>

                          
                                
                          <Button Content="View Details"  Grid.Row="4"
                                  Style="{StaticResource SecondaryButton}"
                                  Click="ViewDetailsClick" HorizontalAlignment="Left"/>
                            

                        </Grid>
                    </Border>

                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</UserControl>
