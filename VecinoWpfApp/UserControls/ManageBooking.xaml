<UserControl x:Class="VecinoWpfApp.UserControls.Bookings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VecinoWpfApp.UserControls"
             xmlns:conv ="clr-namespace:VecinoWpfApp.Converters"
              xmlns:main ="clr-namespace:VecinoWpfApp"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1645">

    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f8fafc" Offset="0"/>
            <GradientStop Color="#e6f1fb" Offset="0.5"/>
            <GradientStop Color="#cfe5fc" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Resources>
        <conv:BookingStatusToVisibilityConverter x:Key="BookingStatusToVisibilityConverter"/>
        <conv:BookingStatusToNameConverter x:Key="BookingStatusToNameConverter"/>
        <main:UrlConverter x:Key="UrlConverter"></main:UrlConverter>

        <!-- Card Border Style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="3" ShadowDepth="1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Approve Button -->
        <Style x:Key="ApproveButton" TargetType="Button">
            <Setter Property="Background" Value="#eaf3de"/>
            <Setter Property="Foreground" Value="#3b6d11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#c0dd97"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Reject Button -->
        <Style x:Key="RejectButton" TargetType="Button">
            <Setter Property="Background" Value="#fcebeb"/>
            <Setter Property="Foreground" Value="#a32d2d"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f09595"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- View Details Button -->
        <Style x:Key="ViewButton" TargetType="Button">
            <Setter Property="Background" Value="#e6f1fb"/>
            <Setter Property="Foreground" Value="#185fa5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#b5d4f4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter ComboBox Style -->
        <Style x:Key="FilterComboBox" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Shared Table Row DataTemplate -->
        <DataTemplate x:Key="BookingRowTemplate">
            <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="28,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="180"/>
                        
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <!-- Booking ID -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding Booking.BookingId}"
                               FontFamily="Segoe UI Mono, Consolas" FontSize="12"
                               Foreground="#94a3b8"
                               VerticalAlignment="Center"/>

                    <!-- Resident -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="30" Height="30" CornerRadius="15"
                                Background="#e6f1fb" Margin="0,0,8,0">
                        
                                <Border.Clip>
                                    <EllipseGeometry Center="15,15" RadiusX="15" RadiusY="15"/>
                                </Border.Clip>
                                <Image Stretch="UniformToFill" Source="{Binding ResidentImage,Converter={StaticResource UrlConverter}}"></Image>
                          
                           
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ResidentName}"
                                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0f172a"/>
                            <TextBlock Text="22"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#94a3b8"/>
                        </StackPanel>
                    </StackPanel>

                 
                   

                    <!-- Date -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding Booking.BookingDate}"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#334155"
                               VerticalAlignment="Center"/>

                    <!-- Time -->
                    <TextBlock Grid.Column="3"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#334155"
                               VerticalAlignment="Center">
                        <Run Text="{Binding Booking.StartTime}"/>
                        <Run Text=" – "/>
                        <Run Text="{Binding Booking.EndTime}"/>
                    </TextBlock>

                    <!-- Note -->
                    <TextBlock Grid.Column="4"
                               Text="{Binding Booking.BookingNote}"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#94a3b8"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,12,0"/>

                    <!-- Status Badge -->
                    <Border Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Left"
                            CornerRadius="10" Padding="10,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#faeeda"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="CONFIRMED">
                                        <Setter Property="Background" Value="#eaf3de"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="REJECTED">
                                        <Setter Property="Background" Value="#fcebeb"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="AWAITING_PAYMENT">
                                        <Setter Property="Background" Value="#e6f1fb"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Booking.BookingStatus, Converter={StaticResource BookingStatusToNameConverter}}"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#633806"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="CONFIRMED">
                                            <Setter Property="Foreground" Value="#3b6d11"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="REJECTED">
                                            <Setter Property="Foreground" Value="#a32d2d"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="AWAITING_PAYMENT">
                                            <Setter Property="Foreground" Value="#0c447c"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- Actions -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        
                        <Button Content="Approve"
                                Style="{StaticResource ApproveButton}"
                                Height="30" Width="78"
                                Margin="0,0,6,0"
                           
                                Visibility="{Binding Booking.BookingStatus, Converter={StaticResource BookingStatusToVisibilityConverter}}"
                                Click="ApproveBooking"/>
                        <Button Content="Reject"
                                Style="{StaticResource RejectButton}"
                                Height="30" Width="68"
                            
                                Visibility="{Binding Booking.BookingStatus, Converter={StaticResource BookingStatusToVisibilityConverter}}"
                                Click="RejectBooking"/>
                    </StackPanel>

                </Grid>
            </Border>
        </DataTemplate>
        <!-- Past Booking Row Template (no Approve/Reject actions) -->
        <DataTemplate x:Key="PastBookingRowTemplate">
            <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="28,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                       Text="{Binding Booking.BookingId}"
                       FontFamily="Segoe UI Mono, Consolas" FontSize="12"
                       Foreground="#94a3b8"
                       VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="30" Height="30" CornerRadius="15"
                        Background="#e6f1fb" Margin="0,0,8,0">
                            <Border.Clip>
                                <EllipseGeometry Center="15,15" RadiusX="15" RadiusY="15"/>
                            </Border.Clip>
                            <Image Stretch="UniformToFill" Source="{Binding ResidentImage,Converter={StaticResource UrlConverter}}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ResidentName}"
                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                               Foreground="#0f172a"/>
                            <TextBlock Text="22"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#94a3b8"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                       Text="{Binding Booking.BookingDate}"
                       FontFamily="Segoe UI" FontSize="13"
                       Foreground="#334155"
                       VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="3"
                       FontFamily="Segoe UI" FontSize="13"
                       Foreground="#334155"
                       VerticalAlignment="Center">
                <Run Text="{Binding Booking.StartTime}"/>
                <Run Text=" – "/>
                <Run Text="{Binding Booking.EndTime}"/>
                    </TextBlock>

                    <TextBlock Grid.Column="4"
                       Text="{Binding Booking.BookingNote}"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="#94a3b8"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,12,0"/>

                    <Border Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Left"
                    CornerRadius="10" Padding="10,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#faeeda"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="CONFIRMED">
                                        <Setter Property="Background" Value="#eaf3de"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="REJECTED">
                                        <Setter Property="Background" Value="#fcebeb"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="AWAITING_PAYMENT">
                                        <Setter Property="Background" Value="#e6f1fb"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Booking.BookingStatus, Converter={StaticResource BookingStatusToNameConverter}}"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#633806"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="CONFIRMED">
                                            <Setter Property="Foreground" Value="#3b6d11"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="REJECTED">
                                            <Setter Property="Foreground" Value="#a32d2d"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Booking.BookingStatus}" Value="AWAITING_PAYMENT">
                                            <Setter Property="Foreground" Value="#0c447c"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- Actions column intentionally left empty for past bookings -->
                </Grid>
            </Border>
        </DataTemplate>
        <!-- Shared ListView Item Container Style -->
        <Style x:Key="BookingListItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Canvas>

        <!-- Page Header -->
        <TextBlock Canvas.Left="80" Canvas.Top="28"
                   Text="Room Bookings"
                   FontFamily="Segoe UI" FontSize="27" FontWeight="SemiBold"
                   Foreground="#1e293b"/>
        <TextBlock Canvas.Left="80" Canvas.Top="69"
                   Text="Review and manage resident booking requests"
                   FontFamily="Segoe UI" FontSize="15"
                   Foreground="#64748b"/>

       
        


        <!-- Summary Stats Row -->
        <!-- Awaiting Approval Card -->
        <Border Canvas.Left="80" Canvas.Top="120" Width="220" Height="80"
                Background="White" CornerRadius="12"
                BorderBrush="#e2e8f0" BorderThickness="1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Awaiting approval" FontFamily="Segoe UI" FontSize="12" Foreground="#64748b"/>
                    <TextBlock x:Name="txtAwaitingCount" Text="{Binding AwaitingApproval}"
                               FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"
                               Foreground="#1e293b" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="36" Height="36" Background="#faeeda" CornerRadius="9" VerticalAlignment="Center">
                    <TextBlock Text="⏳" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Confirmed Card -->
        <Border Canvas.Left="316" Canvas.Top="120" Width="220" Height="80"
                Background="White" CornerRadius="12"
                BorderBrush="#e2e8f0" BorderThickness="1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Confirmed" FontFamily="Segoe UI" FontSize="12" Foreground="#64748b"/>
                    <TextBlock x:Name="txtConfirmedCount" Text="{Binding Confirmed}"
                               FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"
                               Foreground="#1e293b" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="36" Height="36" Background="#eaf3de" CornerRadius="9" VerticalAlignment="Center">
                    <TextBlock Text="✓" FontSize="18" FontWeight="Bold" Foreground="#3b6d11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Awaiting Payment Card -->
        <Border Canvas.Left="552" Canvas.Top="120" Width="220" Height="80"
                Background="White" CornerRadius="12"
                BorderBrush="#e2e8f0" BorderThickness="1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Awaiting payment" FontFamily="Segoe UI" FontSize="12" Foreground="#64748b"/>
                    <TextBlock x:Name="txtPaymentCount" Text="{Binding AwaitingPayment}"
                               FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"
                               Foreground="#1e293b" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="36" Height="36" Background="#e6f1fb" CornerRadius="9" VerticalAlignment="Center">
                    <TextBlock Text="💳" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Rejected Card -->
        <Border Canvas.Left="788" Canvas.Top="120" Width="220" Height="80"
                Background="White" CornerRadius="12"
                BorderBrush="#e2e8f0" BorderThickness="1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Rejected" FontFamily="Segoe UI" FontSize="12" Foreground="#64748b"/>
                    <TextBlock x:Name="txtRejectedCount" Text="{Binding Rejected}"
                               FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"
                               Foreground="#1e293b" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="36" Height="36" Background="#fcebeb" CornerRadius="9" VerticalAlignment="Center">
                    <TextBlock Text="✕" FontSize="18" FontWeight="Bold" Foreground="#a32d2d"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  UPCOMING BOOKINGS TABLE                           -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- Section label -->
        <StackPanel Canvas.Left="80" Canvas.Top="222" Orientation="Horizontal">
            <Border Background="#e6f1fb" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                <TextBlock Text="📅" FontSize="13" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Upcoming Bookings"
                       FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                       Foreground="#1e293b" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Canvas.Left="80" Canvas.Top="252" Width="1510" Height="380" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="54"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0" Background="#f8fafc" CornerRadius="16,16,0,0"
                        BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                    <Grid Margin="28,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="180"/>
                           
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"        FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="RESIDENT"  FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                      
                        <TextBlock Grid.Column="2" Text="DATE"      FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="TIME"      FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="NOTE"      FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="STATUS"    FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="ACTIONS"   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Upcoming Bookings List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="listViewUpcomingBookings"
                              ItemTemplate="{StaticResource BookingRowTemplate}"
                              ItemContainerStyle="{StaticResource BookingListItem}"
                              HorizontalContentAlignment="Stretch"
                              BorderThickness="0"
                              Background="Transparent"/>
                </ScrollViewer>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  PAST BOOKINGS TABLE                               -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- Section label -->
        <StackPanel Canvas.Left="80" Canvas.Top="652" Orientation="Horizontal">
            <Border Background="#f1f5f9" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                <TextBlock Text="🕓" FontSize="13" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Past Bookings"
                       FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                       Foreground="#64748b" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Canvas.Left="80" Canvas.Top="682" Width="1510" Height="360" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="54"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header (same columns, slightly muted) -->
                <Border Grid.Row="0" Background="#f8fafc" CornerRadius="16,16,0,0"
                        BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                    <Grid Margin="28,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="180"/>
                            
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"        FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#94a3b8" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="RESIDENT"  FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#94a3b8" VerticalAlignment="Center"/>
                        
                        <TextBlock Grid.Column="2" Text="DATE"      FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#94a3b8" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="TIME"      FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#94a3b8" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="NOTE"      FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#94a3b8" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="STATUS"    FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#94a3b8" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="ACTIONS"   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#94a3b8" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Past Bookings List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="listViewPastBookings"
                              ItemTemplate="{StaticResource PastBookingRowTemplate}"
                              ItemContainerStyle="{StaticResource BookingListItem}"
                              HorizontalContentAlignment="Stretch"
                              BorderThickness="0"
                              Background="Transparent"
                              Opacity="0.75"/>
                </ScrollViewer>

            </Grid>
        </Border>

    </Canvas>
</UserControl>
