<UserControl x:Class="VecinoWpfApp.UserControls.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1670">

    <UserControl.Background>
        <SolidColorBrush Color="#f8fafc"/>
    </UserControl.Background>

    <UserControl.Resources>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="InfoTile" TargetType="Border">
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#33FFFFFF" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <DockPanel Margin="72,28,72,28" LastChildFill="True">

        <!-- Top bar -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding WelcomeMessage}" FontFamily="Segoe UI" FontSize="22"
                           FontWeight="SemiBold" Foreground="#1e293b"/>
                <TextBlock Text="{Binding TodayDate}" FontFamily="Segoe UI" FontSize="13"
                           Foreground="#94a3b8" Margin="0,3,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Hero strip: codes + next event -->
        <Border DockPanel.Dock="Top" CornerRadius="12" Height="110" Margin="0,0,0,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0f9e8e" Offset="0"/>
                    <GradientStop Color="#2563eb" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Entrance code -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="32,0">
                    <TextBlock Text="ENTRANCE CODE" FontFamily="Segoe UI" FontSize="10"
                               FontWeight="SemiBold" Foreground="White" Opacity="0.6"/>
                    <TextBlock Text="{Binding Building.EntranceCode}" FontFamily="Segoe UI Mono"
                               FontSize="28" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding Building.EntranceName}" FontFamily="Segoe UI"
                               FontSize="11" Foreground="White" Opacity="0.55" Margin="0,2,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Fill="White" Opacity="0.18" Margin="0,16"/>

                <!-- Join code -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="32,0">
                    <TextBlock Text="JOIN CODE" FontFamily="Segoe UI" FontSize="10"
                               FontWeight="SemiBold" Foreground="White" Opacity="0.6"/>
                    <TextBlock Text="{Binding Building.JoinCode}" FontFamily="Segoe UI Mono"
                               FontSize="28" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Button x:Name="BtnCopyJoinCode" Content="Copy"
                                Style="{StaticResource GhostButton}" Padding="10,4" Margin="0,0,6,0"/>
                        <Button x:Name="BtnRefreshJoinCode" Content="Refresh"
                                Style="{StaticResource GhostButton}" Padding="10,4"/>
                    </StackPanel>
                </StackPanel>

                <Rectangle Grid.Column="3" Fill="White" Opacity="0.18" Margin="0,16"/>

                <!-- Next event -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="32,0">
                    <TextBlock Text="NEXT EVENT" FontFamily="Segoe UI" FontSize="10"
                               FontWeight="SemiBold" Foreground="White" Opacity="0.6"/>
                    <TextBlock Text="{Binding NextEvent.EventTitle}" FontFamily="Segoe UI"
                               FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,0"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding NextEvent.EventDate}" FontFamily="Segoe UI"
                               FontSize="11" Foreground="White" Opacity="0.55" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: activity feed + right sidebar -->
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Recent Activity (wider, full height) -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#f8fafc" CornerRadius="12,12,0,0"
                            BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                        <Grid Margin="18,0">
                            <TextBlock Text="Recent activity" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#1e293b"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Activity list -->
                    <ListView x:Name="ListViewActivity" Grid.Row="1"
                              BorderThickness="0" Background="Transparent"
                              HorizontalContentAlignment="Stretch"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="18,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon circle -->
                                        <Border Width="26" Height="26" CornerRadius="13"
                                                Background="{Binding IconBackground}"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Title + timestamp -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Title}" FontFamily="Segoe UI"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="#1e293b"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Timestamp}" FontFamily="Segoe UI"
                                                       FontSize="11" Foreground="#94a3b8" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Badge -->
                                        <Border Grid.Column="2" CornerRadius="20" Padding="8,3"
                                                Background="{Binding BadgeBackground}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Badge}" FontFamily="Segoe UI"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{Binding BadgeForeground}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Right column -->
            <StackPanel Grid.Column="2" VerticalAlignment="Stretch">

                <!-- Needs attention -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="Needs attention" FontFamily="Segoe UI" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1e293b" Margin="0,0,0,12"/>

                        <!-- Overdue fees -->
                        <Border Style="{StaticResource InfoTile}" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#e11d48" CornerRadius="2" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Unpaid fees" FontFamily="Segoe UI" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#1e293b"/>
                                    <TextBlock Text="Overdue this month" FontFamily="Segoe UI"
                                               FontSize="11" Foreground="#94a3b8" Margin="0,1,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" Background="#fee2e2" CornerRadius="20" Padding="8,3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding BuildingStats.UnpaidFees}" FontFamily="Segoe UI"
                                               FontSize="12" FontWeight="SemiBold" Foreground="#b91c1c"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Open service requests -->
                        <Border Style="{StaticResource InfoTile}" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#f97316" CornerRadius="2" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Open requests" FontFamily="Segoe UI" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#1e293b"/>
                                    <TextBlock Text="Maintenance &amp; service" FontFamily="Segoe UI"
                                               FontSize="11" Foreground="#94a3b8" Margin="0,1,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" Background="#fff7ed" CornerRadius="20" Padding="8,3" VerticalAlignment="Center">
                                    <TextBlock  Text="{Binding BuildingStats.OpenRequests}" FontFamily="Segoe UI"
                                               FontSize="12" FontWeight="SemiBold" Foreground="#c2410c"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Active poll -->
                        <Border Style="{StaticResource InfoTile}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#7c3aed" CornerRadius="2" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Active polls" FontFamily="Segoe UI" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#1e293b"/>
                                    <TextBlock Text="Awaiting resident votes" FontFamily="Segoe UI"
                                               FontSize="11" Foreground="#94a3b8" Margin="0,1,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" Background="#ede9fe" CornerRadius="20" Padding="8,3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding BuildingStats.OpenPolls}" FontFamily="Segoe UI"
                                               FontSize="12" FontWeight="SemiBold" Foreground="#6d28d9"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Building snapshot -->
                <Border Style="{StaticResource Card}" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="Building snapshot" FontFamily="Segoe UI" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1e293b" Margin="0,0,0,12"/>
                        <UniformGrid Columns="2" Rows="2">
                            <Border Style="{StaticResource InfoTile}" Margin="0,0,5,5">
                                <StackPanel>
                                    <TextBlock Text="FEES COLLECTED" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#94a3b8"/>
                                    <TextBlock Text="{Binding BuildingStats.PaidFees}" FontFamily="Segoe UI"
                                               FontSize="18" FontWeight="SemiBold" Foreground="#16a34a" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InfoTile}" Margin="5,0,0,5">
                                <StackPanel>
                                    <TextBlock Text="OCCUPANCY" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#94a3b8"/>
                                    <TextBlock FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                                               Foreground="#3b82f6" Margin="0,4,0,0" Text="{Binding BuildingStats.Occupancy}">
                                        
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InfoTile}" Margin="0,5,5,0">
                                <StackPanel>
                                    <TextBlock Text="ELEVATOR" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#94a3b8"/>
                                    <TextBlock Text="{Binding ElevatorStatus}" FontFamily="Segoe UI"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#16a34a" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding ElevatorLastChecked}" FontFamily="Segoe UI"
                                               FontSize="10" Foreground="#94a3b8" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InfoTile}" Margin="5,5,0,0">
                                <StackPanel>
                                    <TextBlock Text="NOTIFICATIONS" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#94a3b8"/>
                                    <TextBlock Text="{Binding BuildingStats.NotificationsSentThisMonth}" FontFamily="Segoe UI"
                                               FontSize="18" FontWeight="SemiBold" Foreground="#14b8a6" Margin="0,4,0,0"/>
                                    <TextBlock Text="sent this month" FontFamily="Segoe UI"
                                               FontSize="10" Foreground="#94a3b8" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
