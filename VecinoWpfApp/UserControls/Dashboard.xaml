<UserControl x:Class="VecinoWpfApp.UserControls.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1670">

    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f8fafc" Offset="0"/>
            <GradientStop Color="#f0fdf4" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Resources>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="InfoTile" TargetType="Border">
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#14b8a6" Offset="0"/>
                                    <GradientStop Color="#3b82f6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#f1f5f9"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#33FFFFFF" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <DockPanel Margin="82,24,82,24" LastChildFill="True">

        <!-- Top bar -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Welcome back, Ofek" FontFamily="Segoe UI" FontSize="24"
                           FontWeight="SemiBold" Foreground="#1e293b"/>
                <TextBlock Text="Vecino admin dashboard" FontFamily="Segoe UI" FontSize="13"
                           Foreground="#64748b" Margin="0,3,0,0"/>
            </StackPanel>
         
        </Grid>

        <!-- Hero card -->
        <Border DockPanel.Dock="Top" CornerRadius="12" Height="118" Margin="0,0,0,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0f9e8e" Offset="0"/>
                    <GradientStop Color="#2563eb" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="28,0">
                    <TextBlock Text="BUILDING" FontFamily="Segoe UI" FontSize="10"
                               FontWeight="SemiBold" Foreground="White" Opacity="0.6"/>
                    <TextBlock Text="{Binding Building.Address}" FontFamily="Segoe UI" FontSize="20"
                               FontWeight="SemiBold" Foreground="White" Margin="0,5,0,0"/>
                    <TextBlock  FontFamily="Segoe UI"
                               FontSize="12" Foreground="White" Opacity="0.6" Margin="0,3,0,0">
                        <TextBlock.Text>

                            <MultiBinding StringFormat="{}{0} · {1} floors · {2} units">
                                <Binding Path="CityName" />
                                <Binding Path="Building.Floors" />
                                <Binding Path="Building.TotalUnits" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <Rectangle Grid.Column="1" Fill="White" Opacity="0.18" Margin="0,16"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="28,0">
                    <TextBlock Text="ENTRANCE CODE" FontFamily="Segoe UI" FontSize="10"
                               FontWeight="SemiBold" Foreground="White" Opacity="0.6"/>
                    <TextBlock x:Name="EntranceCodeText" Text="{Binding Building.EntranceCode}" FontFamily="Segoe UI Mono"
                               FontSize="30" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding Building.EntranceName}" FontFamily="Segoe UI" FontSize="12"
                               Foreground="White" Opacity="0.55" Margin="0,2,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Fill="White" Opacity="0.18" Margin="0,16"/>

                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="28,0">
                    <TextBlock Text="JOIN CODE" FontFamily="Segoe UI" FontSize="10"
                               FontWeight="SemiBold" Foreground="White" Opacity="0.6"/>
                    <TextBlock x:Name="JoinCodeText" Text="{Binding Building.JoinCode}" FontFamily="Segoe UI Mono"
                               FontSize="30" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Copy" Style="{StaticResource GhostButton}"
                                Padding="10,4" Margin="0,0,6,0" />
                        <Button Content="Refresh" Style="{StaticResource GhostButton}"
                                Padding="10,4" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stat cards row -->
        <UniformGrid DockPanel.Dock="Top" Rows="1" Columns="6" Height="72" Margin="0,0,0,10">
            <Border Style="{StaticResource Card}" Margin="0,0,10,0" Padding="14,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Residents" FontFamily="Segoe UI" FontSize="11" Foreground="#64748b"/>
                    <TextBlock Text="24" FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold" Foreground="#14b8a6" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="0,0,10,0" Padding="14,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Active tenants" FontFamily="Segoe UI" FontSize="11" Foreground="#64748b"/>
                    <TextBlock Text="18" FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold" Foreground="#3b82f6" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="0,0,10,0" Padding="14,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Fees collected" FontFamily="Segoe UI" FontSize="11" Foreground="#64748b"/>
                    <TextBlock Text="75%" FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold" Foreground="#16a34a" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="0,0,10,0" Padding="14,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Outstanding" FontFamily="Segoe UI" FontSize="11" Foreground="#64748b"/>
                    <TextBlock Text="6" FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold" Foreground="#e11d48" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="0,0,10,0" Padding="14,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Open requests" FontFamily="Segoe UI" FontSize="11" Foreground="#64748b"/>
                    <TextBlock Text="3" FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold" Foreground="#f97316" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Padding="14,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Next meeting" FontFamily="Segoe UI" FontSize="11" Foreground="#64748b"/>
                    <TextBlock Text="May 3" FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold" Foreground="#7c3aed" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Bottom two columns -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Recent Activity -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#f8fafc" CornerRadius="12,12,0,0"
                            BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                        <TextBlock Text="Recent activity" FontFamily="Segoe UI" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1e293b"
                                   VerticalAlignment="Center" Margin="18,0"/>
                    </Border>
                    <ListView x:Name="ListViewActivity" Grid.Row="1"
                              BorderThickness="0" Background="Transparent"
                              HorizontalContentAlignment="Stretch">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="18,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28" Height="28" CornerRadius="14"
                                                Background="{Binding IconBackground}"
                                                HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontFamily="Segoe UI"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="#1e293b"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Timestamp}" FontFamily="Segoe UI"
                                                       FontSize="11" Foreground="#94a3b8" Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" CornerRadius="20" Padding="7,2"
                                                Background="{Binding BadgeBackground}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Badge}" FontFamily="Segoe UI"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding BadgeForeground}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Right column -->
            <StackPanel Grid.Column="2" VerticalAlignment="Top">

                <!-- Building info — 2x2 tile grid -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Building info" FontFamily="Segoe UI" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1e293b" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2" Rows="2">
                            <Border Style="{StaticResource InfoTile}" Margin="0,0,5,5">
                                <StackPanel>
                                    <TextBlock Text="ADDRESS" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#94a3b8"/>
                                    <TextBlock Text="Haim Laskob 6" FontFamily="Segoe UI" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#0f172a" Margin="0,3,0,0"/>
                                    <TextBlock Text="Tel Aviv" FontFamily="Segoe UI" FontSize="11"
                                               Foreground="#64748b"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InfoTile}" Margin="5,0,0,5">
                                <StackPanel>
                                    <TextBlock Text="STRUCTURE" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#94a3b8"/>
                                    <TextBlock Text="6 floors" FontFamily="Segoe UI" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#0f172a" Margin="0,3,0,0"/>
                                    <TextBlock Text="24 units" FontFamily="Segoe UI" FontSize="11"
                                               Foreground="#64748b"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InfoTile}" Margin="0,5,5,0">
                                <StackPanel>
                                    <TextBlock Text="ELEVATOR" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#94a3b8"/>
                                    <TextBlock Text="Operational" FontFamily="Segoe UI" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#16a34a" Margin="0,3,0,0"/>
                                    <TextBlock Text="Last checked Apr 20" FontFamily="Segoe UI"
                                               FontSize="11" Foreground="#64748b"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InfoTile}" Margin="5,5,0,0">
                                <StackPanel>
                                    <TextBlock Text="MANAGER" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#94a3b8"/>
                                    <TextBlock Text="Ofek" FontFamily="Segoe UI" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#0f172a" Margin="0,3,0,0"/>
                                    <TextBlock Text="Admin" FontFamily="Segoe UI" FontSize="11"
                                               Foreground="#64748b"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Quick actions -->
                <Border Style="{StaticResource Card}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Quick actions" FontFamily="Segoe UI" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1e293b" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2" Rows="2">
                            <Button Content="+ Add Fee" Style="{StaticResource PrimaryButton}"
                                    Padding="0,10" Margin="0,0,5,5" />
                            <Button Content="+ Resident" Style="{StaticResource SecondaryButton}"
                                    Padding="0,10" Margin="5,0,0,5"/>
                            <Button Content="Announce" Style="{StaticResource SecondaryButton}"
                                    Padding="0,10" Margin="0,5,5,0" />
                            <Button Content="Export" Style="{StaticResource SecondaryButton}"
                                    Padding="0,10" Margin="5,5,0,0" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>