<UserControl x:Class="VecinoWpfApp.UserControls.Polls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:VecinoWpfApp.UserControls"
             xmlns:conv="clr-namespace:VecinoWpfApp"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#F0F2F5"
             FontFamily="Segoe UI" d:Height="1080" d:Width="1645">

    <UserControl.Resources>
     

        <!-- Colors -->
        <SolidColorBrush x:Key="PageBg"        Color="#EEF1F6"/>
        <SolidColorBrush x:Key="CardBg"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentTeal"    Color="#4DD9AC"/>
        <SolidColorBrush x:Key="AccentTealBg"  Color="#E6FAF4"/>
        <SolidColorBrush x:Key="IconBg"        Color="#DDE8F8"/>
        <SolidColorBrush x:Key="BarFill"       Color="#D6E8FB"/>
        <SolidColorBrush x:Key="BarEmpty"      Color="#F0F4FA"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#1A1D23"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8A93A8"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#B0BAC9"/>
        <SolidColorBrush x:Key="DividerColor"  Color="#E8ECF2"/>

        <!-- Card Style -->
        <Style x:Key="PollCard" TargetType="Border">
            <Setter Property="Background"    Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius"  Value="16"/>
            <Setter Property="Padding"       Value="28,24"/>
            <Setter Property="Margin"        Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Direction="270"
                                      Color="#000000" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Voted Badge -->
        <Style x:Key="VotedBadge" TargetType="Border">
            <Setter Property="Background"        Value="{StaticResource AccentTealBg}"/>
            <Setter Property="CornerRadius"      Value="8"/>
            <Setter Property="Padding"           Value="12,5"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <!-- Meta Text -->
        <Style x:Key="MetaText" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="Foreground"        Value="{StaticResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

       
        <Style x:Key="CreatePollButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentTeal}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="22,0"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="+" FontSize="18" FontWeight="Light"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3BC99A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2DB589"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <conv:StatusConverter x:Key="statusConverter">

        </conv:StatusConverter>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBg}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="48,36,48,40">
            <StackPanel HorizontalAlignment="Stretch">

                <!-- ── Page Header ── -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Community Polls"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Have your say on community decisions"
                                   FontSize="14" Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Create Poll"
                            Style="{StaticResource CreatePollButton}"
                            VerticalAlignment="Center" Click="ButtonPoll_Click"
                           />
                </Grid>


                <ListView x:Name="listViewPolls" HorizontalContentAlignment="Stretch" Height="918" Background="Transparent" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                                <Border Style="{StaticResource PollCard}" Margin="0 25 0 0">
                                    <StackPanel>

                                      
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            
                                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12"
                         Background="{StaticResource IconBg}" Margin="0,0,16,0">
                                                <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets"
                                FontSize="20" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Foreground="#5B8FD4"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding poll.PollTitle}"
                                FontSize="17" FontWeight="Bold"
                                Foreground="{StaticResource TextPrimary}"
                                TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding poll.PollDescription}"
                                FontSize="13" Margin="0,4,0,0"
                                Foreground="{StaticResource TextSecondary}"
                                TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Border Grid.Column="2" Style="{StaticResource VotedBadge}" Margin="16,0,0,0">
                                                <TextBlock Text="{Binding poll.IsActive,Converter={StaticResource statusConverter}}" FontSize="12" FontWeight="SemiBold"
                                Foreground="{StaticResource AccentTeal}"/>
                                            </Border>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Foreground="{StaticResource TextMuted}"
                            VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="Amenities" Style="{StaticResource MetaText}" Margin="0,0,16,0"/>

                                            <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Foreground="{StaticResource TextMuted}"
                            VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="30/09/2025" Style="{StaticResource MetaText}" Margin="0,0,16,0"/>

                                            <TextBlock Text="&#xE902;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Foreground="{StaticResource TextMuted}"
                            VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="62 votes" Style="{StaticResource MetaText}"/>
                                        </StackPanel>

                                        <Border Height="1" Background="{StaticResource DividerColor}" Margin="0,0,0,18"/>

                                        <!-- Result bar: Yes — 60% -->
                                    <ListView ItemsSource="{Binding options}" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                            <Grid Margin="0,0,0,10" Height="46">
                                                                <Border CornerRadius="8" Background="{StaticResource BarEmpty}"/>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="3*"/>
                                                                        <ColumnDefinition Width="2*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0" CornerRadius="8,0,0,8"
                                                                        Background="{StaticResource BarFill}"/>
                                                                </Grid>
                                                    <TextBlock Text="{Binding option.OptionText}" FontSize="14" FontWeight="SemiBold"
                                                                    Foreground="{StaticResource TextPrimary}"
                                                                    VerticalAlignment="Center" Margin="16,0,0,0"/>
                                                                <TextBlock Text="60%" FontSize="14" FontWeight="Bold"
                                                                Foreground="{StaticResource TextPrimary}"
                                                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                                                Margin="0,0,16,0"/>
                                                            </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                       

                                        

                                     
                                        <TextBlock Text="You are viewing results as an administrator."
                        FontSize="12" FontStyle="Italic"
                        Foreground="{StaticResource TextMuted}"
                        Margin="0,10,0,0" HorizontalAlignment="Center"/>

                                    </StackPanel>
                                </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
               

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>