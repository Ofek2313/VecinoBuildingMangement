<UserControl x:Class="VecinoWpfApp.UserControls.Announcement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VecinoWpfApp.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1645"  d:Background="#f8fafc">
    <UserControl.Resources>
        <Style x:Key="FormTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1e293b"></Setter>
            <Setter Property="FontSize" Value="15"></Setter>
            <Setter Property="FontFamily" Value="Segoe UI"></Setter>
            <Setter Property="FontWeight" Value="Medium"></Setter>
        </Style>
        <Style x:Key="FormField" TargetType="TextBox">
            <Setter Property="Padding" Value="16,12"></Setter>
            <Setter Property="FontSize" Value="14"></Setter>
            <Setter Property="FontFamily" Value="Segoe UI"></Setter>
            <Setter Property="Background" Value="#f8fafc"></Setter>
            <Setter Property="Foreground" Value="#1e293b"></Setter>
            <Setter Property="BorderBrush" Value="#cbd5e1"></Setter>
            <Setter Property="BorderThickness" Value="1"></Setter>

        </Style>
        <Style x:Key="FormFieldComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="#f8fafc" 
                        BorderBrush="#cbd5e1" 
                        BorderThickness="1">
                            <Grid>
                                <ContentPresenter x:Name="ContentSite"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        Margin="16,12,40,12"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False"/>
                                <ToggleButton Background="Transparent"
                                    BorderThickness="0"
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    Focusable="False"/>
                                <Popup IsOpen="{TemplateBinding IsDropDownOpen}">
                                    <Border Background="White" BorderBrush="#cbd5e1" BorderThickness="1">
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="button" TargetType="Button">
            <Setter Property="Background" Value="#6366f1">

            </Setter>
            <Setter Property="FontFamily" Value="Segoe UI"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="FontWeight" Value="SemiBold"></Setter>
            <Setter Property="Width" Value="125"></Setter>
            <Setter Property="Height" Value="45"></Setter>
            <Setter Property="FontSize" Value="17"></Setter>
            <Setter Property="Cursor" Value="Hand"></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                 CornerRadius="8" 
                 Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Background" Value="Red"></Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                          CornerRadius="6" 
                          Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

        <Style x:Key="borderDesgin" TargetType="Border">
            <Setter Property="Background" Value="White"></Setter>
            <Setter Property="CornerRadius" Value="16"></Setter>
            <Setter Property="BorderBrush" Value="#e2e8f0"></Setter>

            <Setter Property="HorizontalAlignment" Value="Center"></Setter>
            <Setter Property="VerticalAlignment" Value="Top"></Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect 
                    Color="Black"
                    Opacity="0.05"
                    BlurRadius="3"
                    ShadowDepth="1"
                    Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="importantBade" TargetType="Border">
            <Setter Property="Background" Value="#fff4e6"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
    </UserControl.Resources>
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f8fafc" Offset="0"/>
            <GradientStop Color="#e0e7ff" Offset="0.5"/>
            <GradientStop Color="#f3e8ff" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <Canvas>
        <TextBlock Canvas.Left="80" TextWrapping="Wrap" Text="Announcements Management" Canvas.Top="26" Height="44" Width="423" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="30" Foreground="#1e293b" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBlock Canvas.Left="80" TextWrapping="Wrap" Canvas.Top="70" Height="44" Width="423" FontFamily="Segoe UI" FontWeight="Normal" FontSize="15" Foreground="#1e293b" HorizontalAlignment="Left" VerticalAlignment="Center"><Run Text="Create, view, and manage system announcements"/><LineBreak/><Run/><LineBreak/><Run/></TextBlock>
        <Border Height="514" Width="1427" Canvas.Left="80" Canvas.Top="130" 
        Style="{StaticResource borderDesgin}">



            <StackPanel Orientation="Vertical" Margin="0,0,0,1">
                <TextBlock Foreground="#1e293b" FontWeight="SemiBold" FontSize="25" Margin="25 20 0 25">
                    Create New Announcement
                </TextBlock>
                <TextBlock Style="{StaticResource FormTitle}" Margin="26 0 0 5 "> Title</TextBlock>
                <TextBox Height="44" Width="1187" Text="Enter announcement title" Style="{StaticResource FormField}" Margin="0 0 190 0 ">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock Style="{StaticResource FormTitle}" Margin="26 25 0 5 "> Message</TextBlock>
                <TextBox Height="128" Width="1187" Text="Enter announcement message" Style="{StaticResource FormField}" Margin="0 0 190 0 ">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock Style="{StaticResource FormTitle}" Margin="26 25 0 5 "> Priorty</TextBlock>
                <ComboBox Style="{StaticResource FormFieldComboBox}" Margin="0 0 190 0"
          Height="44" 
          Width="1180"
          SelectedIndex="0">
                    <ComboBoxItem Content="Normal"/>
                    <ComboBoxItem Content="Important"/>
                    <ComboBoxItem Content="Urgent"/>
                </ComboBox>
                <Button Content="Send Announcment" Margin="0,25,1100,0" Style="{StaticResource button}"  BorderThickness="0" Width="276"/>
            </StackPanel>

        </Border>

        <Border Height="380" Width="1420" Canvas.Left="80" Canvas.Top="669"  Style="{StaticResource borderDesgin}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" Grid.Column="0">
                    <TextBlock Foreground="#1e293b" FontWeight="SemiBold" FontSize="25" Margin="25 20 0 25">
                    Previous Announcements
                    </TextBlock>


                    <StackPanel Margin="25 0 0 0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="A Residential Meeting" 
                            FontSize="16" 
                            FontWeight="SemiBold" 
                            Foreground="#1f2937"
                            Margin="0,0,15,0"/>
                            <Border Style="{StaticResource importantBade}">
                                <TextBlock Text="Important" 
                        FontSize="13" 
                        FontWeight="SemiBold" 
                        Foreground="Red"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="A Residential meeting was schudled for the end of february" 
                FontSize="13" 
                Foreground="#6b7280"
                Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Send Date - 12/02/2026" FontSize="12" Foreground="#9ca3af"/>
                        </StackPanel>
                    </StackPanel>






                </StackPanel>
                <Button Content="Delete"  Style="{StaticResource DeleteButton}" Margin="1183,88,87,260"/>
                <Border Height="1" 
                    Margin="8,166,8,213"
                    Background="#E5E7EB"
                    Opacity="0.7"/>
            </Grid>


        </Border>
    </Canvas>
</UserControl>
