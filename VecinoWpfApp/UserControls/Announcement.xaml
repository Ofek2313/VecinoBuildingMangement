<UserControl x:Class="VecinoWpfApp.UserControls.Announcement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VecinoWpfApp.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1645">

    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f8fafc" Offset="0"/>
            <GradientStop Color="#e0e7ff" Offset="0.5"/>
            <GradientStop Color="#f3e8ff" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Resources>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="3" ShadowDepth="1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Background" Value="#fee2e2"/>
            <Setter Property="Foreground" Value="#e11d48"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Add Announcement Button Style -->
        <Style x:Key="AddButton" TargetType="Button">
            <Setter Property="Background" Value="#6366f1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4f46e5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Priority Badge Styles -->
        <Style x:Key="NormalBadge" TargetType="Border">
            <Setter Property="Background" Value="#eff6ff"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style x:Key="ImportantBadge" TargetType="Border">
            <Setter Property="Background" Value="#fef3c7"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style x:Key="UrgentBadge" TargetType="Border">
            <Setter Property="Background" Value="#fee2e2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

    </UserControl.Resources>

    <Canvas>

        <!-- Page Header -->
        <TextBlock Canvas.Left="80" Canvas.Top="28"
                   Text="Announcements"
                   FontFamily="Segoe UI" FontSize="27" FontWeight="SemiBold"
                   Foreground="#1e293b"/>
        <TextBlock Canvas.Left="80" Canvas.Top="69"
                   Text="View and manage all system announcements"
                   FontFamily="Segoe UI" FontSize="15"
                   Foreground="#64748b"/>

        <!-- Add Announcement Button -->
        <Button x:Name="btnAddAnnouncement"
                Canvas.Left="1422" Canvas.Top="68"
                Width="168" Height="36"
                Content="+ Add Announcement"
                Style="{StaticResource AddButton}" Click="btnAddAnnouncement_Click"/>

        <!-- Announcements Card -->
        <Border Canvas.Left="80" Canvas.Top="118" Width="1510" Height="900" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="54"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0" Background="#f8fafc" CornerRadius="16,16,0,0"
                        BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                    <Grid Margin="28,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TITLE"    FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="PRIORITY" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="MESSAGE"  FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="DATE"     FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="ACTIONS"  FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="#64748b" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="listViewAnnc"
                              HorizontalContentAlignment="Stretch"
                              BorderThickness="0"
                              Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="28,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="300"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Title -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding NotificationTitle}"
                                                   FontFamily="Segoe UI" FontSize="14"
                                                   FontWeight="SemiBold" Foreground="#0f172a"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Priority Badge -->
                                        <Border Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left"
                                                CornerRadius="10" Padding="10,4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#eff6ff"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Important">
                                                            <Setter Property="Background" Value="#fef3c7"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Urgent">
                                                            <Setter Property="Background" Value="#fee2e2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Priority}"
                                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#3b82f6"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Priority}" Value="Important">
                                                                <Setter Property="Foreground" Value="#d97706"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Priority}" Value="Urgent">
                                                                <Setter Property="Foreground" Value="#e11d48"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Message -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding NotificationMessage}"
                                                   FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="#64748b"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,20,0"/>

                                        <!-- Date -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="13" Height="13" Fill="#9ca3af"
                                                  VerticalAlignment="Center" Stretch="Uniform"
                                                  Data="M9 2a1 1 0 0 1 1 1v1h4V3a1 1 0 1 1 2 0v1h3a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h3V3a1 1 0 0 1 1-1zM8 6H5v3h14V6h-3v1a1 1 0 1 1-2 0V6h-4v1a1 1 0 0 1-2 0V6zm11 5H5v8h14v-8z"/>
                                            <TextBlock Text="{Binding NotificationDate}"
                                                       FontFamily="Segoe UI" FontSize="12"
                                                       Foreground="#9ca3af"
                                                       Margin="7,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" >
                                            <Button x:Name="ViewDetailsButton" Content="View Details" Click="ViewDetails_Click"
Height="30" Width="90" Margin="0,0,8,0"
Cursor="Hand" >
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="#eff6ff" CornerRadius="6" Padding="14,6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#e0e7ff"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Foreground>
                                                    <SolidColorBrush Color="#6366f1"/>
                                                </Button.Foreground>
                                                <Button.FontFamily>Segoe UI</Button.FontFamily>
                                                <Button.FontSize>12</Button.FontSize>
                                                <Button.FontWeight>SemiBold</Button.FontWeight>
                                            </Button>
                                            <Button  x:Name="DeleteButton"
                                               Content="Delete"
                                               Style="{StaticResource DeleteButton}"
                                               Height="30" Width="70"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Click="DeleteButton_Click"/>
                                        </StackPanel>
                                        <!-- Delete -->
                                     

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>

    </Canvas>
</UserControl>