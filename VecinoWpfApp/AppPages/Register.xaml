<Page x:Class="VecinoWpfApp.AppPages.Register"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vecino – Create Account"
        Height="1080" Width="1980"
       >

    <Page.Resources>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,13,14,13"/>
            <Setter Property="CaretBrush" Value="#14b8a6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,13,14,13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="11">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#14b8a6" Offset="0"/>
                                    <GradientStop Color="#3b82f6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#14b8a6" Opacity="0.3"
                                                  BlurRadius="10" ShadowDepth="3" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0d9488"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="txt"
                                   Text="{TemplateBinding Content}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   Foreground="{TemplateBinding Foreground}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="Foreground" Value="#3b82f6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#ef4444"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#f8fafc" Offset="0"/>
                <GradientStop Color="#e0f2fe" Offset="0.5"/>
                <GradientStop Color="#f0fdf4" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="700" Height="700"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-300,-300,0" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0A3b82f6" Offset="0"/>
                    <GradientStop Color="#003b82f6" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="600" Height="600"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="-200,0,0,-200" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0814b8a6" Offset="0"/>
                    <GradientStop Color="#0014b8a6" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="620" Margin="0,60,0,60">

            <!-- Logo + Heading -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Border Width="48" Height="48" CornerRadius="14" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#14b8a6" Offset="0"/>
                                <GradientStop Color="#3b82f6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Data="M5,10 L12,4 L19,10 L19,19 A1,1 0 0 1 18,20 L14,20 L14,15 L10,15 L10,20 L6,20 A1,1 0 0 1 5,19 Z"
                              Fill="White" Stretch="Uniform" Width="22" Height="22"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Vecino"
                               FontFamily="Segoe UI" FontSize="28" FontWeight="Bold"
                               Foreground="#0f172a" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Create your account"
                           FontFamily="Segoe UI" FontSize="30" FontWeight="Bold"
                           Foreground="#0f172a" HorizontalAlignment="Center"/>
                <TextBlock Text="Join Vecino and connect with your building community"
                           FontFamily="Segoe UI" FontSize="14" Foreground="#64748b"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Card -->
            <Border Background="White" CornerRadius="20"
                    BorderBrush="#e2e8f0" BorderThickness="1"
                    Padding="48,40">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.06"
                                      BlurRadius="28" ShadowDepth="5" Direction="270"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Full Name + Phone -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Full name" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="NameTextBox"
                                     Style="{StaticResource InputField}" Height="50"/>
                            <TextBlock x:Name="ErrName" Text="Full name is required."
                                       Style="{StaticResource ErrorText}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Phone number" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="PhoneTextBox"
                                     Style="{StaticResource InputField}" Height="50"/>
                            <TextBlock x:Name="ErrPhone" Text="Phone number is required."
                                       Style="{StaticResource ErrorText}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Email -->
                    <TextBlock Text="Email address" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="EmailTextBox"
                             Style="{StaticResource InputField}"
                             Height="50" Margin="0,0,0,4"/>
                    <TextBlock x:Name="ErrEmail" Text="Please enter a valid email."
                               Style="{StaticResource ErrorText}" Margin="0,0,0,20"/>

                    <!-- Password + Confirm -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="PasswordTextBox"
                                         Style="{StaticResource PasswordField}" Height="50"/>
                            <TextBlock x:Name="ErrPassword" Text="Minimum 6 characters."
                                       Style="{StaticResource ErrorText}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Confirm password" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="TxtConfirmPassword"
                                         Style="{StaticResource PasswordField}" Height="50"/>
                            <TextBlock x:Name="ErrConfirmPassword" Text="Passwords do not match."
                                       Style="{StaticResource ErrorText}"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Buttons -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Height="50" Cursor="Hand"
                        >
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="White"
                                    BorderBrush="#e2e8f0" BorderThickness="1.5"
                                    CornerRadius="11">
                                <TextBlock Text="Back to sign in"
                                           FontFamily="Segoe UI" FontSize="15"
                                           FontWeight="SemiBold" Foreground="#64748b"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2"
                        Style="{StaticResource PrimaryButton}" Click="Button_Click"
                       >
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="White" VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Create Account" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,18,0,0">
                <TextBlock Text="Already have an account? "
                           FontFamily="Segoe UI" FontSize="13" Foreground="#64748b"/>
                <Button Content="Sign in instead"
                        Style="{StaticResource GhostButton}"
                        />
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>