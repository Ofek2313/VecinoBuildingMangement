<Page x:Class="VecinoWpfApp.AppPages.LogInPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Vecino"
        Height="1080" Width="1980"
       >

    <Page.Resources>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,13,14,13"/>
            <Setter Property="CaretBrush" Value="#14b8a6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,13,14,13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="11">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#14b8a6" Offset="0"/>
                                    <GradientStop Color="#3b82f6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#14b8a6" Opacity="0.3" BlurRadius="10" ShadowDepth="3" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0d9488"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="txt"
                                   Text="{TemplateBinding Content}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   Foreground="{TemplateBinding Foreground}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="Foreground" Value="#3b82f6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#ef4444"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <Style x:Key="FeaturePill" TargetType="Border">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="#2AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1000"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ LEFT PANEL ══════════════ -->
        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#14b8a6" Offset="0"/>
                    <GradientStop Color="#3b82f6" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,48,48" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing>
                                <GeometryDrawing.Pen>
                                    <Pen Brush="#08FFFFFF" Thickness="1"/>
                                </GeometryDrawing.Pen>
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <LineGeometry StartPoint="48,0" EndPoint="48,48"/>
                                        <LineGeometry StartPoint="0,48" EndPoint="48,48"/>
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <StackPanel VerticalAlignment="Center" Margin="72,0,64,0">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,60">
                    <Border Width="48" Height="48" CornerRadius="14" Margin="0,0,14,0"
                            Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1">
                        <Path Data="M5,10 L12,4 L19,10 L19,19 A1,1 0 0 1 18,20 L14,20 L14,15 L10,15 L10,20 L6,20 A1,1 0 0 1 5,19 Z"
                              Fill="White" Stretch="Uniform" Width="22" Height="22"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Vecino" FontFamily="Segoe UI" FontSize="26" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock FontFamily="Segoe UI" FontSize="44" FontWeight="Bold"
                           Foreground="White" LineHeight="54" Margin="0,0,0,20">
                    Your building,<LineBreak/>beautifully managed.
                </TextBlock>

                <TextBlock Text="The all-in-one platform for building administrators. Manage residents, events, polls, and announcements from one elegant dashboard."
                           FontFamily="Segoe UI" FontSize="16" FontWeight="Light"
                           Foreground="#BEffffff" TextWrapping="Wrap"
                           LineHeight="26" Margin="0,0,0,52"/>

                <Border Style="{StaticResource FeaturePill}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" CornerRadius="8" Margin="0,0,14,0" Background="#20FFFFFF">
                            <Path Data="M3,5 L21,5 M3,12 L21,12 M3,19 L21,19"
                                  Stroke="White" StrokeThickness="2"
                                  Width="16" Height="14" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Instant announcements to all residents"
                                   FontFamily="Segoe UI" FontSize="14" FontWeight="Medium"
                                   Foreground="#F0FFFFFF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FeaturePill}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" CornerRadius="8" Margin="0,0,14,0" Background="#20FFFFFF">
                            <Path Data="M9,11 L12,14 L22,4 M21,12 A9,9 0 1 1 12,3"
                                  Stroke="White" StrokeThickness="2"
                                  Width="16" Height="16" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Community polls with real-time results"
                                   FontFamily="Segoe UI" FontSize="14" FontWeight="Medium"
                                   Foreground="#F0FFFFFF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FeaturePill}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" CornerRadius="8" Margin="0,0,14,0" Background="#20FFFFFF">
                            <Path Data="M17,21 L17,13 L7,13 L7,21 M3,21 L21,21 M3,10 L12,3 L21,10"
                                  Stroke="White" StrokeThickness="2"
                                  Width="16" Height="16" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Full resident and unit management"
                                   FontFamily="Segoe UI" FontSize="14" FontWeight="Medium"
                                   Foreground="#F0FFFFFF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>

        <!-- ══════════════ RIGHT PANEL ══════════════ -->
        <Grid Grid.Column="1">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#f8fafc" Offset="0"/>
                    <GradientStop Color="#e0f2fe" Offset="0.5"/>
                    <GradientStop Color="#f0fdf4" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse Width="500" Height="500" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-200,-200,0" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#0A3b82f6" Offset="0"/>
                        <GradientStop Color="#003b82f6" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="400" Height="400" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-150,0,0,-150" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#0814b8a6" Offset="0"/>
                        <GradientStop Color="#0014b8a6" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="500" Background="White" CornerRadius="24"
                    BorderBrush="#e2e8f0" BorderThickness="1" Height="570">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.07"
                                      BlurRadius="30" ShadowDepth="6" Direction="270"/>
                </Border.Effect>

                <StackPanel Margin="48,44,48,44">

                    <TextBlock FontFamily="Segoe UI" FontSize="26" FontWeight="Bold"
                               Foreground="#0f172a" Margin="0,0,0,6">
                        Welcome back
                    </TextBlock>
                    <TextBlock Text="Sign in to your Vecino admin account"
                               FontFamily="Segoe UI" FontSize="14" Foreground="#64748b"
                               Margin="0,0,0,32"/>

                    <TextBlock Text="Email address" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,4">
                        <TextBox x:Name="txtEmail" Style="{StaticResource InputField}" Height="50"/>

                    </Grid>
                    <TextBlock x:Name="errEmail" Text="Please enter a valid email."
                               Style="{StaticResource ErrorText}" Margin="0,0,0,12"/>

                    <TextBlock Text="Password" Style="{StaticResource FieldLabel}" Margin="0,8,0,7"/>
                    <Grid Margin="0,0,0,4">
                        <PasswordBox x:Name="txtPassword" Style="{StaticResource PasswordField}" Height="50"/>

                    </Grid>
                    <TextBlock x:Name="errPassword" Text="Password is required."
                               Style="{StaticResource ErrorText}" Margin="0,0,0,16"/>

                    <Grid Margin="0,4,0,30">
                        <CheckBox x:Name="chkRemember" Content="Keep me signed in"
                                  FontFamily="Segoe UI" FontSize="13" Foreground="#64748b"
                                  HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Button Content="Forgot password?"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <Button x:Name="btnSignIn" Content="Sign In"
                            Style="{StaticResource PrimaryButton}" Click="btnSignIn_Click"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                        <TextBlock Text="New to Vecino? "
                                   FontFamily="Segoe UI" FontSize="13" Foreground="#64748b"/>
                        <Button Content="Get Started"
                                Style="{StaticResource GhostButton}" Click="CreateBuildingButton_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>