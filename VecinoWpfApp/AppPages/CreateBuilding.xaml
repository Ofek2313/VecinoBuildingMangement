<Page x:Class="VecinoWpfApp.AppPages.CreateBuilding"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vecino – Create Building"
        Height="1080" Width="1980"
       >

    <Page.Resources>
        
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,13,14,13"/>
            <Setter Property="CaretBrush" Value="#14b8a6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="11">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#14b8a6" Offset="0"/>
                                    <GradientStop Color="#3b82f6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#14b8a6" Opacity="0.3"
                                                  BlurRadius="10" ShadowDepth="3" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0d9488"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="txt"
                                   Text="{TemplateBinding Content}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   Foreground="{TemplateBinding Foreground}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="Foreground" Value="#3b82f6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#ef4444"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
        <Style x:Key="UploadPreviewArea" TargetType="Border">
            <Setter Property="Height" Value="140"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style x:Key="PlaceholderIconCircle" TargetType="Border">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Style.Resources>
                <LinearGradientBrush x:Key="IconBg" StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#e0f2fe" Offset="0"/>
                    <GradientStop Color="#dcfce7" Offset="1"/>
                </LinearGradientBrush>
            </Style.Resources>
          
        </Style>
        <Style x:Key="IconCircleContainer" TargetType="Border">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#e0f2fe" Offset="0"/>
                        <GradientStop Color="#dcfce7" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                        CornerRadius="10"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#14b8a6"/>
                                <Setter TargetName="border" Property="Background" Value="#f0fdfa"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#ccfbf1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter"></BooleanToVisibilityConverter>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#f8fafc" Offset="0"/>
                <GradientStop Color="#e0f2fe" Offset="0.5"/>
                <GradientStop Color="#f0fdf4" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="700" Height="700"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-300,-300,0" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0A3b82f6" Offset="0"/>
                    <GradientStop Color="#003b82f6" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="600" Height="600"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="-200,0,0,-200" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0814b8a6" Offset="0"/>
                    <GradientStop Color="#0014b8a6" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Width="660" Margin="0,60,0,60">

                <!-- Logo + Heading -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border Width="48" Height="48" CornerRadius="14" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#14b8a6" Offset="0"/>
                                    <GradientStop Color="#3b82f6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M5,10 L12,4 L19,10 L19,19 A1,1 0 0 1 18,20 L14,20 L14,15 L10,15 L10,20 L6,20 A1,1 0 0 1 5,19 Z"
                                  Fill="White" Stretch="Uniform" Width="22" Height="22"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Vecino"
                                   FontFamily="Segoe UI" FontSize="28" FontWeight="Bold"
                                   Foreground="#0f172a" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Create your building"
                               FontFamily="Segoe UI" FontSize="30" FontWeight="Bold"
                               Foreground="#0f172a" HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter your building's details to get started"
                               FontFamily="Segoe UI" FontSize="14" Foreground="#64748b"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Card -->
                <Border Background="White" CornerRadius="20"
                        BorderBrush="#e2e8f0" BorderThickness="1"
                        Padding="48,40">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.06"
                                          BlurRadius="28" ShadowDepth="5" Direction="270"/>
                    </Border.Effect>

                    <StackPanel>

                       

                        <!-- Preview Area (static border, just shows the image) -->
                        <TextBlock Text="Building image" Style="{StaticResource FieldLabel}"/>

                        <Border x:Name="ImagePreviewBorder" Height="140" CornerRadius="12" 
        BorderBrush="#e2e8f0" BorderThickness="1.5" Background="#f8fafc" 
        Margin="0,0,0,10" ClipToBounds="True">
                            <Grid>
                                <StackPanel x:Name="ImagePlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">

                                    <Border Style="{StaticResource IconCircleContainer}">
                                        <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" 
                           FontSize="20" Foreground="#14b8a6"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="No image selected" FontFamily="Segoe UI" FontSize="13"
                       FontWeight="SemiBold" Foreground="#64748b" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Upload a photo using the button below" FontFamily="Segoe UI" 
                       FontSize="11" Foreground="#94a3b8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>

                                <Image x:Name="ImagePreview" Stretch="Fill" Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <!-- Upload Button -->
                        <Button x:Name="ImageUploadButton"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,0,4" 
                        Click="ImageUploadButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE898;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" Foreground="#14b8a6"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                                <TextBlock Text="Upload photo"
                                   FontFamily="Segoe UI" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#0d9488"
                                   VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="ErrImage" Text="Please upload a building image."
                                   Style="{StaticResource ErrorText}" Margin="0,0,0,20"/>

                        <!-- Address -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Street address" Style="{StaticResource FieldLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
     Visibility="{Binding (Validation.HasError),
          Converter={StaticResource VisibilityConverter},
          ElementName=AddressTextBox}">
                                <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Canvas Width="14" Height="14">
                                        <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
      Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                        <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
        Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                        <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
      Fill="#e24b4a"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=AddressTextBox}"
                            FontFamily="Segoe UI" FontSize="11.5"
                            Foreground="#a32d2d"
                            VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <TextBox x:Name="AddressTextBox"
                                 Style="{StaticResource InputField}"
                                 Height="50" Margin="0,0,0,4"
                                 Text="{Binding Address,UpdateSourceTrigger=PropertyChanged}"/>
                        

                        <!-- City + Zip -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="City" Style="{StaticResource FieldLabel}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
Visibility="{Binding (Validation.HasError),
     Converter={StaticResource VisibilityConverter},
     ElementName=CmbCity}">
                                        <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <Canvas Width="14" Height="14">
                                                <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
 Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                                <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
   Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                                <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
 Fill="#e24b4a"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=CmbCity}"
                       FontFamily="Segoe UI" FontSize="11.5"
                       Foreground="#a32d2d"
                       VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <ComboBox  x:Name="CmbCity"
                                  FontFamily="Segoe UI" FontSize="13"
                                  Padding="10,8"
                                  Background="#f8fafc"
                                  BorderBrush="#e2e8f0"
                                   DisplayMemberPath="CityName"
                                SelectedValuePath="CityId"  
                                  SelectedValue="{Binding CityId}">
                                    
                                </ComboBox>
                                
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Code" Style="{StaticResource FieldLabel}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
Visibility="{Binding (Validation.HasError),
     Converter={StaticResource VisibilityConverter},
     ElementName=CmbCity}">
                                        <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <Canvas Width="14" Height="14">
                                                <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
 Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                                <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
   Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                                <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
 Fill="#e24b4a"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=CmbCity}"
                       FontFamily="Segoe UI" FontSize="11.5"
                       Foreground="#a32d2d"
                       VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                               
                                <TextBox x:Name="CodeTextBox"
                                         Style="{StaticResource InputField}" Height="50" Text="{Binding EntranceCode,UpdateSourceTrigger=PropertyChanged}"/>
                               
                            </StackPanel>
                        </Grid>

                        <!-- Entrance + Total Units + Floors -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Entrance" Style="{StaticResource FieldLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
Visibility="{Binding (Validation.HasError),
     Converter={StaticResource VisibilityConverter},
     ElementName=EntranceNameTextBox}">
                                    <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Canvas Width="14" Height="14">
                                            <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
 Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                            <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
   Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                            <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
 Fill="#e24b4a"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=EntranceNameTextBox}"
                       FontFamily="Segoe UI" FontSize="11.5"
                       Foreground="#a32d2d"
                       VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox x:Name="EntranceNameTextBox"
                                         Style="{StaticResource InputField}" Height="50" Text="{Binding EntranceName,UpdateSourceTrigger=PropertyChanged}"/>
                                
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Total units" Style="{StaticResource FieldLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
Visibility="{Binding (Validation.HasError),
     Converter={StaticResource VisibilityConverter},
     ElementName=TotalUnitsTextBox}">
                                    <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Canvas Width="14" Height="14">
                                            <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
 Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                            <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
   Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                            <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
 Fill="#e24b4a"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=TotalUnitsTextBox}"
                       FontFamily="Segoe UI" FontSize="11.5"
                       Foreground="#a32d2d"
                       VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox x:Name="TotalUnitsTextBox"
                                         Style="{StaticResource InputField}" Height="50" Text="{Binding TotalUnits,UpdateSourceTrigger=PropertyChanged}"/>
                               
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Floors" Style="{StaticResource FieldLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
Visibility="{Binding (Validation.HasError),
     Converter={StaticResource VisibilityConverter},
     ElementName=FloorsTextBox}">
                                    <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Canvas Width="14" Height="14">
                                            <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
 Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                            <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
   Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                            <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
 Fill="#e24b4a"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=FloorsTextBox}"
                       FontFamily="Segoe UI" FontSize="11.5"
                       Foreground="#a32d2d"
                       VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox x:Name="FloorsTextBox"
                                         Style="{StaticResource InputField}" Height="50" Text="{Binding Floors,UpdateSourceTrigger=PropertyChanged}"/>
                               
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Height="50" Cursor="Hand"
                            >
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="White"
                                        BorderBrush="#e2e8f0" BorderThickness="1.5"
                                        CornerRadius="11">
                                    <TextBlock Text="Cancel"
                                               FontFamily="Segoe UI" FontSize="15"
                                               FontWeight="SemiBold" Foreground="#64748b"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource PrimaryButton}" Click="CreateBuildingButton_Click"
                            >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="White" VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Create Building" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,18,0,0">
                    <TextBlock Text="Already have a building? "
                               FontFamily="Segoe UI" FontSize="13" Foreground="#64748b"/>
                    <Button Content="Sign in instead"
                            Style="{StaticResource GhostButton}" Click="Button_Click"
                           />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>