<Window x:Class="VecinoWpfApp.AppWindows.NewAnnouncement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv ="clr-namespace:VecinoWpfApp"
        Title="New Announcement"
        Height="720" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter"></BooleanToVisibilityConverter>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#6366f1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="0,12">
                            <Border.Effect>
                                <DropShadowEffect Color="#6366f1" Opacity="0.25" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4f46e5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background" Value="#f1f5f9"/>
            <Setter Property="Foreground" Value="#64748b"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="0,12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#f09595"/>
                                <Setter TargetName="border" Property="Background" Value="#fff5f5"/>
                            </Trigger>
                            <Trigger Property="Validation.HasError" Value="False">
                                <Setter TargetName="border" Property="BorderBrush" Value="#14b8a6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ResidentCheckItem" TargetType="Border">
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

    </Window.Resources>

    <Border Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Border Grid.Row="0" CornerRadius="18,18,0,0"
                    BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#f8fafc" Offset="0"/>
                        <GradientStop Color="#e0e7ff" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="24,0">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="#6366f1" Margin="0,0,12,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#6366f1" Opacity="0.3" BlurRadius="8" ShadowDepth="0"/>
                            </Border.Effect>
                            <TextBlock Text="📢" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="New Announcement"
                                       FontFamily="Segoe UI" FontSize="17" FontWeight="SemiBold"
                                       Foreground="#1e293b"/>
                            <TextBlock Text="Fill in the details to publish an announcement"
                                       FontFamily="Segoe UI" FontSize="11" Foreground="#64748b"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== FORM BODY ===== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20,24,8">
                <StackPanel>

                    
                    
                     <TextBlock Text="Announcement Title" Style="{StaticResource LabelText}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                      Visibility="{Binding (Validation.HasError),
                      Converter={StaticResource VisibilityConverter},
                      ElementName=AnnouncementTitleTextBox}">
                        <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                            <Canvas Width="14" Height="14">
                                <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
                                Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
                                Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
                                Fill="#e24b4a"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=AnnouncementTitleTextBox}"
                        FontFamily="Segoe UI" FontSize="11.5"
                        Foreground="#a32d2d"
                        VerticalAlignment="Center"/>
                    </StackPanel>



                    <TextBox x:Name="AnnouncementTitleTextBox"
                             Style="{StaticResource InputBox}"
                             Height="40" Margin="0,0,0,16" Text="{Binding NotificationTitle,UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Announcement Message -->
                    <TextBlock Text="Announcement Message" Style="{StaticResource LabelText}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                        Visibility="{Binding (Validation.HasError),
                         Converter={StaticResource VisibilityConverter},
                         ElementName=AnnouncementMessageTextBox}">
                        <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                            <Canvas Width="14" Height="14">
                                <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
                                Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
                                Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
                                Fill="#e24b4a"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=AnnouncementMessageTextBox}"
                        FontFamily="Segoe UI" FontSize="11.5"
                        Foreground="#a32d2d"
                        VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox x:Name="AnnouncementMessageTextBox"
                             Style="{StaticResource InputBox}"
                             Height="100"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             Padding="12,10"
                             Margin="0,0,0,16"
                             Text="{Binding NotificationMessage,UpdateSourceTrigger=PropertyChanged}" />

                    <!-- Priority -->
                    <TextBlock Text="Priority" Style="{StaticResource LabelText}"/>
                    <Border Background="#f8fafc" BorderBrush="#e2e8f0" BorderThickness="1"
                            CornerRadius="8" Margin="0,0,0,16">
                        <ComboBox x:Name="CmbPriority"
                                  FontFamily="Segoe UI" FontSize="13"
                                  Foreground="#0f172a"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Height="40" Padding="10,0"
                                  VerticalContentAlignment="Center" SelectedValuePath="Content" SelectedValue="{Binding Priority,UpdateSourceTrigger=PropertyChanged}">
                            <ComboBoxItem Content="Normal" IsSelected="True"/>
                            <ComboBoxItem Content="Important"/>
                            <ComboBoxItem Content="Urgent"/>
                        </ComboBox>
                    </Border>

                    <!-- Pin Announcement -->
                    <Border Background="#eff6ff" BorderBrush="#bfdbfe" BorderThickness="1"
                            CornerRadius="10" Padding="14,12" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="📌  Pin Announcement"
                                           FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#3b82f6"/>
                                <TextBlock Text="Pinned announcements appear at the top of the board"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#64748b" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkPinMessage"
                                      Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding IsPinned}"/>
                        </Grid>
                    </Border>

                    <!-- ===== ASSIGN TO ===== -->
                    <TextBlock Text="Assign To" Style="{StaticResource LabelText}"/>
                    <TextBlock Text="Select one or more residents"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#94a3b8" Margin="0,0,0,10"/>

                    <!-- Select All — indigo tint -->
                    <Border Background="#eef2ff" BorderBrush="#c7d2fe" BorderThickness="1"
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,8">
                        <CheckBox x:Name="ChkSelectAll"
                                  FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                  Foreground="#4f46e5"
                                  Content="Select All Residents" Checked="ChkSelectAll_Checked" Unchecked="ChkSelectAll_Unchecked" />
                    </Border>

                    <!-- Search Box -->
                    <Border Background="#f8fafc" BorderBrush="#e2e8f0" BorderThickness="1"
                            CornerRadius="10" Padding="12,0" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#94a3b8"/>
                            <TextBox x:Name="TxtSearch"
                                     Grid.Column="1"
                                     Height="40"
                                     FontFamily="Segoe UI" FontSize="13"
                                     Foreground="#0f172a" Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     TextChanged="TxtSearch_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Resources>
                                            <VisualBrush x:Key="HintBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search residents..."
                                                               FontFamily="Segoe UI" FontSize="13"
                                                               Foreground="#cbd5e1"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <!-- Resident List -->
                    <ListView x:Name="ListViewResidents"
                              HorizontalContentAlignment="Stretch"
                              BorderThickness="0"
                              Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ResidentCheckItem}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Avatar -->
                                        <Border Grid.Column="0" Width="32" Height="32"
                                                CornerRadius="16" Background="#e0e7ff">
                                            <TextBlock Text="SR" FontSize="11" FontWeight="Bold"
                                                       Foreground="#6366f1"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding ResidentName}"
                                                       FontFamily="Segoe UI" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="#0f172a"/>
                                            <TextBlock Text="Unit 101"
                                                       FontFamily="Segoe UI" FontSize="11"
                                                       Foreground="#94a3b8"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="2" VerticalAlignment="Center"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>
            </ScrollViewer>

            <!-- ===== FOOTER BUTTONS ===== -->
            <Border Grid.Row="2" BorderBrush="#e2e8f0" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,18,18" Background="#f8fafc">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Cancel"
                            Style="{StaticResource CancelButton}"
                            x:Name="BtnCancel" Click="BtnCancel_Click" />
                    <Button Grid.Column="2" Content="Publish Announcement"
                            Style="{StaticResource PrimaryButton}"
                            x:Name="BtnPublish" Click="BtnPublish_Click" />
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>