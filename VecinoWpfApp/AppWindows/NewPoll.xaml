<Window x:Class="VecinoWpfApp.AppWindows.NewPoll"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:local="clr-namespace:VecinoWpfApp.AppWindows"
        Title="Create Poll"
        Width="580" Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF1F6"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentTeal"    Color="#4DD9AC"/>
        <SolidColorBrush x:Key="CardBg"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#1A1D23"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8A93A8"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#B0BAC9"/>
        <SolidColorBrush x:Key="FieldBg"       Color="#F0F4FA"/>
        <SolidColorBrush x:Key="DividerColor"  Color="#E8ECF2"/>

      
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Height"          Value="52"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Foreground"      Value="#1e293b"/>
            <Setter Property="Background"      Value="#f8fafc"/>
            <Setter Property="BorderBrush"     Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="16,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Height"          Value="52"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Foreground"      Value="#1e293b"/>
            <Setter Property="Background"      Value="#f8fafc"/>
            <Setter Property="BorderBrush"     Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="#f8fafc"
                                BorderBrush="#cbd5e1"
                                BorderThickness="1">
                            <Grid>
                                <ContentPresenter x:Name="ContentSite"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        Margin="16,12,40,12"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False"/>
                                <ToggleButton Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <TextBlock Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12"
                                                           Foreground="#64748b"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,16,0"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       StaysOpen="False">
                                    <Border Background="White"
                                            BorderBrush="#cbd5e1"
                                            BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="12" ShadowDepth="4" Direction="270"/>
                                        </Border.Effect>
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
        </Style>

        <!-- Cancel button -->
        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource FieldBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E6EF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Save button -->
        <Style x:Key="SaveButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentTeal}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3BC99A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2DB589"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBg}"
            CornerRadius="16" Margin="24,10,24,27"
            Padding="32,28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270"
                              Color="#000000" Opacity="0.07"/>
        </Border.Effect>
        <StackPanel>

            <!-- Header -->
            <TextBlock Text="Create New Poll"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Fill in the details below to publish a new community poll."
                       FontSize="13" Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,24"/>

            <Border Height="1" Background="{StaticResource DividerColor}" Margin="0,0,0,24"/>

            <!-- Poll Title -->
            <TextBlock Text="POLL TITLE" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtTitle"
                     Style="{StaticResource InputField}"
                     Margin="0,0,0,18"/>

            <!-- Description -->
            <TextBlock Text="DESCRIPTION" Style="{StaticResource FieldLabel}"/>
            <Border Background="#f8fafc"
                    BorderBrush="#cbd5e1"
                    BorderThickness="1"
                    Margin="0,0,0,18">
                <TextBox x:Name="TxtDescription"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="14,10"
                         FontSize="15"
                         Foreground="#1e293b"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="80"
                         VerticalScrollBarVisibility="Auto"/>
            </Border>

            <!-- Category & Date row -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                  
                    
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="CLOSING DATE" Style="{StaticResource FieldLabel}"/>
                    <DatePicker x:Name="DpClosingDate"
                    Height="52" FontSize="15"
                    Background="#f8fafc"
                    BorderBrush="#cbd5e1"
                    BorderThickness="1" Width="469"/>
                </StackPanel>
            </Grid>

            <!-- Options -->
            <TextBlock Text="OPTIONS" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtOption1"
                     Style="{StaticResource InputField}"
                     Margin="0,0,0,10" Height="30"/>
            <TextBox x:Name="TxtOption2"
                     Style="{StaticResource InputField}"
                     Margin="0,0,0,24" Height="30"/>

            <!-- Action buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancel"
                        Style="{StaticResource CancelButton}"
                      />

                <Button Grid.Column="2" Content="Create Poll"
                        Style="{StaticResource SaveButton}"
                       />
            </Grid>
            
        </StackPanel>
    </Border>
</Window>
