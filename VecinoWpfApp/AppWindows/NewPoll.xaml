<Window x:Class="VecinoWpfApp.AppWindows.NewPoll"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:local="clr-namespace:VecinoWpfApp.AppWindows"
        xmlns:conv="clr-namespace:VecinoWpfApp"
        Title="Create Poll"
        Width="580" Height="850"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF1F6"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentTeal"    Color="#4DD9AC"/>
        <SolidColorBrush x:Key="CardBg"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#1A1D23"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8A93A8"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#B0BAC9"/>
        <SolidColorBrush x:Key="FieldBg"       Color="#F0F4FA"/>
        <SolidColorBrush x:Key="DividerColor"  Color="#E8ECF2"/>

      
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Height"          Value="52"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Foreground"      Value="#1e293b"/>
            <Setter Property="Background"      Value="#f8fafc"/>
            <Setter Property="BorderBrush"     Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="16,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#f09595"/>
                                <Setter TargetName="border" Property="Background" Value="#fff5f5"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#14b8a6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                      
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AddOptionButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AccentTeal}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="{StaticResource AccentTeal}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8FBF4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Height"          Value="52"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Foreground"      Value="#1e293b"/>
            <Setter Property="Background"      Value="#f8fafc"/>
            <Setter Property="BorderBrush"     Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="#f8fafc"
                                BorderBrush="#cbd5e1"
                                BorderThickness="1">
                            <Grid>
                                <ContentPresenter x:Name="ContentSite"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        Margin="16,12,40,12"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False"/>
                                <ToggleButton Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <TextBlock Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12"
                                                           Foreground="#64748b"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,16,0"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       StaysOpen="False">
                                    <Border Background="White"
                                            BorderBrush="#cbd5e1"
                                            BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="12" ShadowDepth="4" Direction="270"/>
                                        </Border.Effect>
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
        </Style>

        <!-- Cancel button -->
        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource FieldBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E6EF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter"></BooleanToVisibilityConverter>
        <!-- Save button -->
        <Style x:Key="SaveButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentTeal}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3BC99A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2DB589"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RemoveOptionButton" TargetType="Button">
            <Setter Property="Width"           Value="38"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Background"      Value="#FCEBEB"/>
            <Setter Property="BorderBrush"     Value="#F7C1C1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8">
                            <Canvas Width="14" Height="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                                <Rectangle Width="10" Height="1.4"
                                   Canvas.Left="2" Canvas.Top="6.3"
                                   Fill="#A32D2D" RadiusX="0.7" RadiusY="0.7"/>
                            </Canvas>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F7C1C1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F09595"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <conv:IndexToVisibilityConverter x:Key="IndexToVisibilityConverter"></conv:IndexToVisibilityConverter>
    </Window.Resources>

    <Border Background="{StaticResource CardBg}"
            CornerRadius="16" Margin="24,10,24,27"
            Padding="32,28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270"
                              Color="#000000" Opacity="0.07"/>
        </Border.Effect>
        <StackPanel>

            <!-- Header -->
            <TextBlock Text="Create New Poll"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Fill in the details below to publish a new community poll."
                       FontSize="13" Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,24"/>

            <Border Height="1" Background="{StaticResource DividerColor}" Margin="0,0,0,24"/>

            <!-- Poll Title -->
            <TextBlock Text="POLL TITLE" Style="{StaticResource FieldLabel}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
     Visibility="{Binding (Validation.HasError),
          Converter={StaticResource VisibilityConverter},
          ElementName=pollTitleTextBox}">
                <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                    <Canvas Width="14" Height="14">
                        <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
      Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                        <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
        Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                        <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
      Fill="#e24b4a"/>
                    </Canvas>
                </Viewbox>
                <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=pollTitleTextBox}"
FontFamily="Segoe UI" FontSize="11.5"
Foreground="#a32d2d"
VerticalAlignment="Center"/>
            </StackPanel>
            <TextBox x:Name="pollTitleTextBox"
                     Style="{StaticResource InputField}"
                     Margin="0,0,0,18"
                     Text="{Binding Poll.PollTitle,UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Description -->
            <TextBlock Text="DESCRIPTION" Style="{StaticResource FieldLabel}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
     Visibility="{Binding (Validation.HasError),
          Converter={StaticResource VisibilityConverter},
          ElementName=pollDescription}">
                <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                    <Canvas Width="14" Height="14">
                        <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
      Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                        <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
        Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                        <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
      Fill="#e24b4a"/>
                    </Canvas>
                </Viewbox>
                <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=pollDescription}"
FontFamily="Segoe UI" FontSize="11.5"
Foreground="#a32d2d"
VerticalAlignment="Center"/>
            </StackPanel>
            <Border Background="#f8fafc"
                    BorderBrush="#cbd5e1"
                    BorderThickness="1"
                    Margin="0,0,0,18">
                <TextBox x:Name="pollDescription"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="14,10"
                         FontSize="15"
                         Foreground="#1e293b"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="80"
                         VerticalScrollBarVisibility="Auto" Text="{Binding Poll.PollDescription,UpdateSourceTrigger=PropertyChanged}"/>
            </Border>

            <!-- Category & Date row -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                  
                    
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="CLOSING DATE" Style="{StaticResource FieldLabel}"/>
                    <DatePicker x:Name="pollDate"
                    Height="52" FontSize="15"
                    Background="#f8fafc"
                    BorderBrush="#cbd5e1"
                    BorderThickness="1" Width="469" SelectedDate="{Binding Poll.PollDate,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <!-- Options -->
            <StackPanel x:Name="optionsPanel" Height="260">
                <TextBlock Text="OPTIONS" Style="{StaticResource FieldLabel}"/>
                <ItemsControl  x:Name="ItemControlOptions" AlternationCount="4"

                    Background="Transparent"
                    HorizontalContentAlignment="Stretch">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel> 
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                    Visibility="{Binding (Validation.HasError),
                                    Converter={StaticResource VisibilityConverter},ElementName=OptionTextBox
                                   }">
                                    <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Canvas Width="14" Height="14">
                                            <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
                                                 Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                            <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
                                                Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                            <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
                                                Fill="#e24b4a"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=OptionTextBox}"
                                FontFamily="Segoe UI" FontSize="11.5"
                                Foreground="#a32d2d"
                                VerticalAlignment="Center"/>


                                </StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="OptionTextBox"
             Grid.Column="0"
             Text="{Binding OptionText, UpdateSourceTrigger=PropertyChanged}"
             Style="{StaticResource InputField}"
             Height="38"/>

                                    <Button Grid.Column="1"
            Margin="8,0,0,0"
            Style="{StaticResource RemoveOptionButton}"
            Visibility="{Binding (ItemsControl.AlternationIndex),
                RelativeSource={RelativeSource AncestorType=ContentPresenter},
                Converter={StaticResource IndexToVisibilityConverter}}"
            
            Click="RemoveOption">-</Button>
                                </Grid>
                            </StackPanel>
                            
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="+ Add Option"
                        x:Name="addOptionButton"
                Style="{StaticResource AddOptionButton}"
                Margin="0,0,0,20" Click="AddOption_Click"/>
            </StackPanel>
           

            <!-- Action buttons -->
            <Grid Margin="0 0 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancel"
                        Style="{StaticResource CancelButton}"
                      />

                <Button Grid.Column="2" Content="Create Poll"
                        Style="{StaticResource SaveButton}" Click="CreatePoll_Click"
                       />
            </Grid>
            
        </StackPanel>
    </Border>
</Window>
