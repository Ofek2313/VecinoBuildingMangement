<Window x:Class="VecinoWpfApp.AppWindows.FeeDetail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fee Detail"
        Height="540" Width="440"
        WindowStartupLocation="CenterOwner"
        Background="Transparent">

    <Border Background="White" CornerRadius="16"
            BorderBrush="#e2e8f0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="68"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0"
                    BorderBrush="#e2e8f0" BorderThickness="0,0,0,1"
                    Padding="24,22,24,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#f0fdf4" Offset="0"/>
                        <GradientStop Color="#ecfdf5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>

                    <!-- Avatar + Name + Badge -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="50" Height="50"
                                CornerRadius="14" Background="#d1fae5"
                                Margin="0,0,14,0">
                            <TextBlock x:Name="TxtInitials" Text="YK"
                                       FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#065f46"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtResident" Text="Yossi Katz"
                                       FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#0f172a"/>
                            <TextBlock x:Name="TxtSubtitle" Text="Monthly Maintenance · RES-004"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#64748b" Margin="0,2,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="2" x:Name="StatusBadge"
                                Background="#fee2e2" CornerRadius="8"
                                Padding="12,5" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtStatus" Text="Unpaid"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#e11d48"/>
                        </Border>
                    </Grid>

                    <!-- Amount + Due Date mini cards -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White"
                                CornerRadius="12" Padding="16,12"
                                BorderBrush="#e2e8f0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Amount due"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#94a3b8" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <TextBlock x:Name="TxtAmount" Text="750"
                                               FontFamily="Segoe UI" FontSize="24" FontWeight="Bold"
                                               Foreground="#0f172a"/>
                                    <TextBlock Text="₪"
                                               FontFamily="Segoe UI" FontSize="14"
                                               Foreground="#64748b"
                                               VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="White"
                                CornerRadius="12" Padding="16,12"
                                BorderBrush="#e2e8f0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Due date"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#94a3b8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtDueDateCard" Text="01/04/2026"
                                           FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                                           Foreground="#e11d48"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== DETAIL ROWS ===== -->
            <StackPanel Grid.Row="1" Margin="24,16,24,8">

                <TextBlock Text="FEE DETAILS"
                           FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                           Foreground="#94a3b8" Margin="0,0,0,10"/>

                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Fee title" FontFamily="Segoe UI" FontSize="12" Foreground="#94a3b8"/>
                        <TextBlock Grid.Column="1" Text="Monthly Maintenance" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#0f172a" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Amount" FontFamily="Segoe UI" FontSize="12" Foreground="#94a3b8"/>
                        <TextBlock Grid.Column="1" Text="750₪" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#0f172a" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Due date" FontFamily="Segoe UI" FontSize="12" Foreground="#94a3b8"/>
                        <TextBlock x:Name="TxtDueDate" Grid.Column="1" Text="01/04/2026" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#0f172a" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Status" FontFamily="Segoe UI" FontSize="12" Foreground="#94a3b8"/>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                            <Border Background="#fee2e2" CornerRadius="6" Padding="10,3">
                                <TextBlock x:Name="TxtStatusRow" Text="Unpaid" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="#e11d48"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Resident ID" FontFamily="Segoe UI" FontSize="12" Foreground="#94a3b8"/>
                        <TextBlock x:Name="TxtResidentId" Grid.Column="1" Text="RES-004" FontFamily="Segoe UI" FontSize="13" Foreground="#64748b" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Payment Date (visible only when paid) -->
                <Border x:Name="PanelPaymentDate" Visibility="Collapsed"
                        BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Paid on" FontFamily="Segoe UI" FontSize="12" Foreground="#94a3b8"/>
                        <TextBlock x:Name="TxtPaymentDate" Grid.Column="1" Text="15/03/2026" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#16a34a" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

            </StackPanel>

            <!-- ===== FOOTER ===== -->
            <Border Grid.Row="2" BorderBrush="#e2e8f0" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,16,16" Background="#f8fafc">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Height="40" Cursor="Hand"
                           >
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#f1f5f9" CornerRadius="10"
                                        BorderBrush="#e2e8f0" BorderThickness="1">
                                    <TextBlock Text="Close"
                                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#64748b"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2" Height="40" Cursor="Hand"
                           >
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#14b8a6" Offset="0"/>
                                            <GradientStop Color="#22c55e" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="✏️  Edit Fee"
                                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>