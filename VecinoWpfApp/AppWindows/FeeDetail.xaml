<Window x:Class="VecinoWpfApp.AppWindows.FeeDetail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fee Detail"
        Height="540" Width="440"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        
       >

    <Window.Resources>
        <Style x:Key="HeaderEditableTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="False">
                    <Setter Property="Background" Value="#F9FAFB"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="#A855F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#fee2e2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#f1f5f9"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#64748b"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="16" BorderBrush="#e2e8f0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="68"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="16,16,0,0" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="24,22,24,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#f0fdf4" Offset="0"/>
                        <GradientStop Color="#ecfdf5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="50" Height="50" CornerRadius="14" Background="#d1fae5" Margin="0,0,14,0">
                            <TextBlock x:Name="TxtInitials" Text="YK" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="#065f46" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtResident" Text="Yossi Katz" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="#0f172a"/>
                            <TextBlock x:Name="TxtSubtitle" Text="Monthly Maintenance · RES-004" FontFamily="Segoe UI" FontSize="12" Foreground="#64748b" Margin="0,2,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="2" Style="{StaticResource StatusBadgeStyle}">
                            <TextBlock x:Name="TxtStatus" Text="Unpaid" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="#e11d48"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,16,24,8">
                <TextBlock Text="FEE DETAILS" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" Foreground="#94a3b8" Margin="0,0,0,10"/>

                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Fee title" Style="{StaticResource DetailLabelStyle}"/>
                        <TextBox x:Name="FeeTitleTextBox" Grid.Column="1" Text="Monthly Maintenance" Style="{StaticResource HeaderEditableTextBoxStyle}"/>
                    </Grid>
                </Border>

                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Amount" Style="{StaticResource DetailLabelStyle}"/>
                        <TextBox Grid.Column="1" Text="750₪" Style="{StaticResource HeaderEditableTextBoxStyle}" />
                    </Grid>
                </Border>

                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Due date" Style="{StaticResource DetailLabelStyle}"/>
                        <TextBox x:Name="TxtDueDate" Grid.Column="1" Text="01/04/2026" Style="{StaticResource HeaderEditableTextBoxStyle}"/>
                    </Grid>
                </Border>

                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Status" Style="{StaticResource DetailLabelStyle}"/>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Border Style="{StaticResource StatusBadgeStyle}" Padding="10,3" CornerRadius="6">
                                <TextBlock x:Name="TxtStatusRow" Text="Unpaid" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="#e11d48"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="PanelPaymentDate" Visibility="Collapsed" BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Paid on" Style="{StaticResource DetailLabelStyle}"/>
                        <TextBlock x:Name="TxtPaymentDate" Grid.Column="1" Text="15/03/2026" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#16a34a" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" BorderBrush="#e2e8f0" BorderThickness="0,1,0,0" CornerRadius="0,0,16,16" Background="#f8fafc">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Close" Style="{StaticResource ActionButtonStyle}"/>

                    <Button x:Name="EditFeeButton"  Grid.Column="2" Style="{StaticResource ActionButtonStyle}" Foreground="White" Click="EditFeeButton_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#14b8a6" Offset="0"/>
                                <GradientStop Color="#22c55e" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Edit Fee" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>