<Window x:Class="VecinoWpfApp.AppWindows.FeeDetail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv ="clr-namespace:VecinoWpfApp"
        Title="Fee Detail"
        Height="540" Width="440"
        WindowStartupLocation="CenterOwner"
        Background="Transparent">

    <Window.Resources>
        <conv:FeeStatusStyleConverter x:Key="feeStatusStyleConverter"/>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseConverter"/>
       
        
        <Style x:Key="HeaderEditableTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="False">
                    <Setter Property="Background" Value="#F9FAFB"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="#22c55e"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#fee2e2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Shared base for all bottom buttons -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#f1f5f9"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#64748b"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Delete: outlined red, lighter visual weight than Edit -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#fff5f5"/>
            <Setter Property="BorderBrush" Value="#fca5a5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#dc2626"/>
        </Style>

        <!-- Confirm Delete: filled red, appears after first click -->
        <Style x:Key="ConfirmDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#dc2626"/>
            <Setter Property="BorderBrush" Value="#dc2626"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <conv:StringToDateConverter x:Key="StringToDateConverter"/>
    </Window.Resources>

    <Border Background="White" CornerRadius="16" BorderBrush="#e2e8f0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="68"/>
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="24,22,24,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#f0fdf4" Offset="0"/>
                        <GradientStop Color="#ecfdf5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="50" Height="50" CornerRadius="14" Background="#d1fae5" Margin="0,0,14,0">
                            <TextBlock x:Name="TxtInitials" Text="YK" FontFamily="Segoe UI" FontSize="16"
                                       FontWeight="SemiBold" Foreground="#065f46"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtResident" Text="{Binding ResidentName}"
                                       FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="#0f172a"/>
                            <TextBlock x:Name="TxtSubtitle" Text="{Binding Fee.FeeTitle}"
                                       FontFamily="Segoe UI" FontSize="12" Foreground="#64748b" Margin="0,2,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="2" Style="{StaticResource StatusBadgeStyle}"
                                Background="{Binding Fee.IsPaid, Converter={StaticResource feeStatusStyleConverter}, ConverterParameter=Badge}">
                            <TextBlock x:Name="TxtStatus"
                                       Text="{Binding Fee.IsPaid, Converter={StaticResource feeStatusStyleConverter}, ConverterParameter=Label}"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding Fee.IsPaid, Converter={StaticResource feeStatusStyleConverter}, ConverterParameter=Text}"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Detail rows ── -->
            <StackPanel Grid.Row="1" Margin="24,16,24,8">
                <TextBlock Text="FEE DETAILS" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                           Foreground="#94a3b8" Margin="0,0,0,10"/>

                <!-- Fee Title -->
                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                        Visibility="{Binding (Validation.HasError), Converter={StaticResource VisibilityConverter}, ElementName=FeeTitleTextBox}">
                                <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Canvas Width="14" Height="14">
                                        <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5" Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                        <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5" Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                        <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3" Fill="#e24b4a"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=FeeTitleTextBox}"
                                           FontFamily="Segoe UI" FontSize="11.5" Foreground="#a32d2d" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Fee title" Style="{StaticResource DetailLabelStyle}"/>
                        </StackPanel>
                        <TextBox x:Name="FeeTitleTextBox" Grid.Column="1"
                                 Text="{Binding Fee.FeeTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource HeaderEditableTextBoxStyle}"/>
                    </Grid>
                </Border>

                <!-- Amount -->
                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                        Visibility="{Binding (Validation.HasError), Converter={StaticResource VisibilityConverter}, ElementName=FeeAmountTextBox}">
                                <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Canvas Width="14" Height="14">
                                        <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5" Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                        <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5" Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                        <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3" Fill="#e24b4a"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=FeeAmountTextBox}"
                                           FontFamily="Segoe UI" FontSize="11.5" Foreground="#a32d2d" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Amount" Style="{StaticResource DetailLabelStyle}"/>
                        </StackPanel>
                        <TextBox x:Name="FeeAmountTextBox" Grid.Column="1"
                                 Text="{Binding Fee.FeeAmount, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource HeaderEditableTextBoxStyle}"/>
                    </Grid>
                </Border>

                <!-- Due Date -->
                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                        Visibility="{Binding (Validation.HasError), Converter={StaticResource VisibilityConverter}, ElementName=DueDatePicker}">
                                <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Canvas Width="14" Height="14">
                                        <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5" Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                        <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5" Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                        <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3" Fill="#e24b4a"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=DueDatePicker}"
                                           FontFamily="Segoe UI" FontSize="11.5" Foreground="#a32d2d"
                                           VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="150"/>
                            </StackPanel>
                            <TextBlock Text="Due date" Style="{StaticResource DetailLabelStyle}"/>
                        </StackPanel>
                        <TextBox x:Name="TxtDueDate" Grid.Column="1"
                                 Text="{Binding Fee.FeeDueDate}"
                                 Style="{StaticResource HeaderEditableTextBoxStyle}"/>
                        <DatePicker x:Name="DueDatePicker" Grid.Column="1"
                                    SelectedDateFormat="Short" HorizontalAlignment="Right"
                                    Focusable="False" FontFamily="Segoe UI" FontSize="13"
                                    FontWeight="SemiBold" Foreground="#0f172a"
                                    BorderThickness="0" Background="Transparent" Visibility="Collapsed"
                                    SelectedDate="{Binding Fee.FeeDueDate, Converter={StaticResource StringToDateConverter}, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>

                <!-- Status -->
                <Border BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Status" Style="{StaticResource DetailLabelStyle}"/>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Border Style="{StaticResource StatusBadgeStyle}" Padding="10,3" CornerRadius="6"
                                    Background="{Binding Fee.IsPaid, Converter={StaticResource feeStatusStyleConverter}, ConverterParameter=Badge}">
                                <TextBlock x:Name="TxtStatusRow"
                                           Text="{Binding Fee.IsPaid, Converter={StaticResource feeStatusStyleConverter}, ConverterParameter=Label}"
                                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding Fee.IsPaid, Converter={StaticResource feeStatusStyleConverter}, ConverterParameter=Text}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Payment date (paid only) -->
                <Border x:Name="PanelPaymentDate"
                        Visibility="{Binding Fee.IsPaid, Converter={StaticResource VisibilityConverter}}"
                        BorderBrush="#f1f5f9" BorderThickness="0,0,0,1" Padding="0,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Paid on" Style="{StaticResource DetailLabelStyle}"/>
                        <TextBlock x:Name="TxtPaymentDate" Grid.Column="1"
                                   Text="{Binding Fee.PaymentDate}"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#16a34a" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ── Bottom action bar ── -->
            <Border Grid.Row="2" BorderBrush="#e2e8f0" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,16,16" Background="#f8fafc">
                <Grid Margin="24,0">
                    <!--
                        Paid state   → Close spans all 5 columns (no Delete, no Edit)
                        Unpaid state → Close | gap | Delete | gap | Edit Fee
                    -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.4*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Close -->
                    <Button Content="Close" Grid.Column="0" x:Name="CloseButton" >
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                <Style.Triggers>
                                    <!-- When paid, stretch across all columns -->
                                    <DataTrigger Binding="{Binding Fee.IsPaid}" Value="True">
                                        <Setter Property="Grid.ColumnSpan" Value="5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!--
                        Delete — two-state:
                          Normal  → outlined red, trash icon + "Delete"
                          Confirm → filled red, "Confirm?" — wired in code-behind
                        Both hidden when fee is already paid.
                    -->
                    <Button x:Name="DeleteFeeButton"
                            Grid.Column="2"
                            Style="{StaticResource DeleteButtonStyle}"
                            Visibility="{Binding Fee.IsPaid, Converter={StaticResource InverseConverter}}"
                            Click="DeleteFeeButton_Click"
                            ToolTip="Delete this fee permanently">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="12"/>
                            <TextBlock x:Name="DeleteButtonLabel" Text="Delete" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Edit Fee -->
                    <Button x:Name="EditFeeButton"
                            Grid.Column="4"
                            Style="{StaticResource ActionButtonStyle}"
                            Foreground="White"
                            Click="EditFeeButton_Click"
                            Visibility="{Binding Fee.IsPaid, Converter={StaticResource InverseConverter}}">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#14b8a6" Offset="0"/>
                                <GradientStop Color="#22c55e" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Edit Fee" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>