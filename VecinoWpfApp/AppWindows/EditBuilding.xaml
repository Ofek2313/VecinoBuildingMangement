<Window x:Class="VecinoWpfApp.AppWindows.EditBuilding"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:VecinoWpfApp"
        Title="Edit building info"
        Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2563eb"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="FooterButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#e2e8f0" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter"></BooleanToVisibilityConverter>
        <conv:UrlConverter x:Key="urlConverter"></conv:UrlConverter>
    </Window.Resources>

    <Border CornerRadius="14" Background="White"
            BorderBrush="#e2e8f0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0" Padding="24,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="38" Height="38" CornerRadius="9" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0f9e8e" Offset="0"/>
                                <GradientStop Color="#2563eb" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="✎" FontSize="16" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Edit building info" FontFamily="Segoe UI"
                                   FontSize="15" FontWeight="SemiBold" Foreground="#1e293b"/>
                        <TextBlock Text="Changes apply to the dashboard and resident app"
                                   FontFamily="Segoe UI" FontSize="12" Foreground="#94a3b8" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2" Content="✕"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#94a3b8" FontSize="14" Cursor="Hand"
                            VerticalAlignment="Top" Padding="6" Click="CloseButton"/>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="24,20">
                <TextBlock Text="BUILDING COVER" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>

                <Border x:Name="ImagePreviewBorder"
            CornerRadius="12"
            Height="180"
            Margin="0,0,0,0"
            ClipToBounds="True"
            Cursor="Hand"
           >
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#e0f2f1" Offset="0"/>
                            <GradientStop Color="#dbeafe" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel x:Name="PlaceholderPanel" VerticalAlignment="Center" HorizontalAlignment="Center" >
                            <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" 
                           FontSize="40" Foreground="#94a3b8" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="upload building photo" FontFamily="Segoe UI" 
                           FontSize="13" Foreground="#64748b" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Image x:Name="BuildingImagePreview"  Stretch="UniformToFill" Source="{Binding BuildingImage,Converter={StaticResource urlConverter},ConverterParameter=Building}"/>
                    </Grid>
                </Border>

                <Grid Margin="0,8,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource FooterButton}" Background="White"
                Padding="16,0" Click="UploadImage_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#2563eb"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Upload photo" FontSize="13" FontWeight="SemiBold" Foreground="#1e293b"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnRemoveImage" Grid.Column="2" Style="{StaticResource FooterButton}" Background="White"
                Padding="16,0"  Click="RemoveImage">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#e24b4a"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Remove" FontSize="13" FontWeight="SemiBold" Foreground="#a32d2d"/>
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock Text="GENERAL" Style="{StaticResource SectionLabel}"/>

                <!-- Address + City -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
     Visibility="{Binding (Validation.HasError),
          Converter={StaticResource VisibilityConverter},
          ElementName=TxtAddress}">
                            <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
      Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                    <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
        Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                    <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
      Fill="#e24b4a"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=TxtAddress}"
FontFamily="Segoe UI" FontSize="11.5"
Foreground="#a32d2d"
VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox x:Name="TxtAddress" Style="{StaticResource FieldInput}"
                                 Text="{Binding Address,UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="City" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
     Visibility="{Binding (Validation.HasError),
          Converter={StaticResource VisibilityConverter},
          ElementName=CmbCity}">
                            <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
      Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                    <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
        Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                    <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
      Fill="#e24b4a"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=CmbCity}"
FontFamily="Segoe UI" FontSize="11.5"
Foreground="#a32d2d"
VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox x:Name="CmbCity"
                                  FontFamily="Segoe UI" FontSize="13"
                                  Padding="10,8"
                                  Background="#f8fafc"
                                  BorderBrush="#e2e8f0"
                                   DisplayMemberPath="CityName"
                                SelectedValuePath="CityId"  
                                  SelectedValue="{Binding CityId,UpdateSourceTrigger=PropertyChanged}">
                                    
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Floors + Units -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Number of floors" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
     Visibility="{Binding (Validation.HasError),
          Converter={StaticResource VisibilityConverter},
          ElementName=TxtFloors}">
                            <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
      Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                    <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
        Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                    <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
      Fill="#e24b4a"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=TxtFloors}"
FontFamily="Segoe UI" FontSize="11.5"
Foreground="#a32d2d"
VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox x:Name="TxtFloors" Style="{StaticResource FieldInput}"
                                 Text="{Binding Floors,UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Number of units" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
     Visibility="{Binding (Validation.HasError),
          Converter={StaticResource VisibilityConverter},
          ElementName=TxtUnits}">
                            <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
      Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                    <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
        Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                    <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
      Fill="#e24b4a"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=TxtUnits}"
FontFamily="Segoe UI" FontSize="11.5"
Foreground="#a32d2d"
VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox x:Name="TxtUnits" Style="{StaticResource FieldInput}"
                                 Text="{Binding TotalUnits,UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <Border Height="1" Background="#e2e8f0" Margin="0,0,0,20"/>

                <!-- Access codes -->
                <TextBlock Text="ACCESS CODES" Style="{StaticResource SectionLabel}"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Entrance code" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
     Visibility="{Binding (Validation.HasError),
          Converter={StaticResource VisibilityConverter},
          ElementName=TxtEntranceCode}">
                            <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
      Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                    <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
        Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                    <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
      Fill="#e24b4a"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=TxtEntranceCode}"
FontFamily="Segoe UI" FontSize="11.5"
Foreground="#a32d2d"
VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox x:Name="TxtEntranceCode" Style="{StaticResource FieldInput}"
                                 FontFamily="Segoe UI Mono" FontSize="14" FontWeight="SemiBold"
                                 Text="{Binding EntranceCode,UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Shown to residents on the app" FontFamily="Segoe UI"
                                   FontSize="11" Foreground="#94a3b8" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Entrance name" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
     Visibility="{Binding (Validation.HasError),
          Converter={StaticResource VisibilityConverter},
          ElementName=TxtEntranceName}">
                            <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
      Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                    <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
        Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                    <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
      Fill="#e24b4a"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=TxtEntranceName}"
FontFamily="Segoe UI" FontSize="11.5"
Foreground="#a32d2d"
VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox x:Name="TxtEntranceName" Style="{StaticResource FieldInput}"
                                 Text="{Binding EntranceName,UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#f8fafc" BorderBrush="#e2e8f0"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,14,14" Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button Content="Cancel"
                            Style="{StaticResource FooterButton}"
                            Background="White" Foreground="#1e293b"
                            Margin="0,0,8,0" Click="CloseButton"/>

                    <Button Content="Save changes" 
                            Style="{StaticResource FooterButton}"
                            Foreground="White" Click="SaveChanges">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0f9e8e" Offset="0"/>
                                <GradientStop Color="#2563eb" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>

                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>