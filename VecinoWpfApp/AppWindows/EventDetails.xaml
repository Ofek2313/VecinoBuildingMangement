<Window
    x:Class="VecinoWpfApp.AppWindows.EventDetails"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:VecinoWpfApp.AppWindows"
    xmlns:conv="clr-namespace:VecinoWpfApp"
    Title="Vecino – Event Details"
    Width="800"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Background="#F3F0FB"
    FontFamily="Segoe UI">

    <Window.Resources>
       
        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
           
        </Style>

        <!-- Value Style -->
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <!-- Info Card Style -->
        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
        </Style>

        <!-- Attendee Card Style -->
        <Style x:Key="AttendeeCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="EditableTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#1e293b"/>

            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="False">
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="#cbd5e1"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Close Button -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f1f5f9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#8B5CF6" Offset="0"/>
                                    <GradientStop Color="#EC4899" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#8B5CF6" Opacity="0.3" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HeaderEditableTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,24"/>

            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,4"/>

            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="False">
                    <Setter Property="Background" Value="#F9FAFB"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="#A855F7"/>
                    <Setter Property="CaretBrush" Value="#A855F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                CornerRadius="10"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FCE7F3"/>
                                <Setter TargetName="border" Property="Background" Value="#FCE7F3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FCE7F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TimeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <conv:UrlConverter x:Key="urlConverter">

        </conv:UrlConverter>
        <conv:StringToDateConverter x:Key="StringToDateConverter" ></conv:StringToDateConverter>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter"></BooleanToVisibilityConverter>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F3F0FB" Offset="0"/>
                <GradientStop Color="#FDF2F8" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="MainScrollbar">
            <Border Width="780"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Background="White"
                    CornerRadius="16"
                    Padding="52,44"
                    Margin="0,24,0,24">
                <Border.Effect>
                    <DropShadowEffect Color="#C4B5FD" BlurRadius="40" ShadowDepth="0" Opacity="0.2"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Header -->
                    <StackPanel Margin="0,0,0,32" HorizontalAlignment="Center">
                        <Border Width="60" Height="60" CornerRadius="30"
                                HorizontalAlignment="Center" Margin="0,0,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#8B5CF6" Offset="0"/>
                                    <GradientStop Color="#EC4899" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE787;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="26"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Event Details"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="View community event information"
                                   FontSize="14"
                                   Foreground="#94a3b8"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Event Image Placeholder -->
                    <Border CornerRadius="12"
                            Height="180"
                            Margin="0,0,0,15"
                            ClipToBounds="True">
                        <Image  Source="{Binding Event.EventImage, Converter={StaticResource urlConverter}}" Stretch="Fill" x:Name="EventImage">
                            
                        </Image>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EDE9FE" Offset="0"/>
                                <GradientStop Color="#FCE7F3" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <!-- Replace this StackPanel with an <Image> bound to your EventImage source -->
                       
                    </Border>
                    <Button x:Name="UploadImage" Visibility="Collapsed"
 Style="{StaticResource SecondaryButton}" Click="UploadImage_Click"
 Margin="0,0,0,4" 
>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;"
            FontFamily="Segoe MDL2 Assets"
            FontSize="14" Foreground="#8B5CF6"
            VerticalAlignment="Center"
            Margin="0,0,8,0"/>
                            <TextBlock Text="Upload photo"
            FontFamily="Segoe UI" FontSize="13"
            FontWeight="SemiBold" Foreground="#7C3AED"
            VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Type Badge -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border CornerRadius="20" Padding="14,6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#EDE9FE" Offset="0"/>
                                    <GradientStop Color="#FCE7F3" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock x:Name="TypeBadge"
                                       Text="Community Meeting"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#7C3AED"/>
                        </Border>
                    </StackPanel>

                    <!-- Title -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
Visibility="{Binding (Validation.HasError),
Converter={StaticResource VisibilityConverter},
ElementName=EventTitleText}">
                            <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
          Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                    <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
          Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                    <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
          Fill="#e24b4a"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=EventTitleText}"
                              FontFamily="Segoe UI" FontSize="11.5"
                              Foreground="#a32d2d"
                              VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox x:Name="EventTitleText"
                               Text="{Binding Event.EventTitle,UpdateSourceTrigger=PropertyChanged}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24"
                             IsReadOnly="True"
                             Style="{StaticResource HeaderEditableTextBoxStyle}"
                             />
                    
                    </StackPanel>
                    <!-- Date / Time / Location Row -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Date -->
                        <Border Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE787;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Foreground="#8B5CF6"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="DATE" Style="{StaticResource LabelStyle}" Margin="0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
   Visibility="{Binding (Validation.HasError),
   Converter={StaticResource VisibilityConverter},
   ElementName=DueDatePicker}">
                                    <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Canvas Width="14" Height="14">
                                            <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
             Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                            <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
             Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                            <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
             Fill="#e24b4a"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=DueDatePicker}"
                                 FontFamily="Segoe UI" FontSize="11.5"
                                 Foreground="#a32d2d"
                                 VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="150"/>
                                </StackPanel>
                                <TextBlock x:Name="EventDateText"
                                           Text="{Binding Event.EventDate}"
                                           Style="{StaticResource ValueStyle}"
                                           FontWeight="SemiBold"/>
                                <DatePicker x:Name="DueDatePicker" 
                                     
                                     SelectedDateFormat="Short"
                                     HorizontalAlignment="Left"
                                    Focusable="False"
                                     FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                     Foreground="#0f172a" BorderThickness="0"
                                     Background="Transparent" Visibility="Collapsed" SelectedDate="{Binding Event.EventDate,Converter={StaticResource StringToDateConverter},UpdateSourceTrigger=PropertyChanged}">
                                    <DatePicker.Resources>
                                        <Style TargetType="DatePickerTextBox">
                                            <!-- Makes the text area background transparent -->
                                            <Setter Property="Background" Value="Transparent"/>
                                            <!-- Removes the inner border that often appears on hover/focus -->
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <!-- Ensures text is vertically centered -->
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <!-- Optional: ensures the watermark "Select a date" is also styled -->
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </DatePicker.Resources>
                                </DatePicker>
                                
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE917;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="14" Foreground="#8B5CF6"
                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="TIME" Style="{StaticResource LabelStyle}" Margin="0"/>
                                </StackPanel>

                                <!-- Read-only combined display -->
                                <TextBlock x:Name="EventTimeText"
                   Style="{StaticResource ValueStyle}"
                   FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} - {1}">
                                            <Binding Path="Event.StartTime"/>
                                            <Binding Path="Event.EndTime"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

                                <!-- Editable Start/End time dropdowns (shown only in edit mode) -->
                                <StackPanel x:Name="TimeEditPanel" Orientation="Horizontal" Visibility="Collapsed">
                                    <ComboBox x:Name="StartTimeBox" Focusable="False"
                      Style="{StaticResource TimeComboBoxStyle}"
                      IsEditable="True"
                      Text="{Binding Event.StartTime, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text=" - " VerticalAlignment="Center"
                       FontWeight="SemiBold" Foreground="#94a3b8" Margin="4,0"/>
                                    <ComboBox x:Name="EndTimeBox" Focusable="False"
                      Style="{StaticResource TimeComboBoxStyle}"
                      IsEditable="True"
                      Text="{Binding Event.EndTime, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Attendee Count -->
                        <Border Grid.Column="4" Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE716;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Foreground="#8B5CF6"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="ATTENDING" Style="{StaticResource LabelStyle}" Margin="0"/>
                                </StackPanel>
                                <TextBlock x:Name="AttendeeCountText"
                                           Text="{Binding Attending,StringFormat={}{0} people}"
                                           Style="{StaticResource ValueStyle}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Description Section -->
                    <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,0,24">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="&#xE70B;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Foreground="#8B5CF6"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="DESCRIPTION" Style="{StaticResource LabelStyle}" Margin="0" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Margin="10,5,0,4"
Visibility="{Binding (Validation.HasError),
Converter={StaticResource VisibilityConverter},
ElementName=EventDescriptionText}">
                                    <Viewbox Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Canvas Width="14" Height="14">
                                            <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
          Stroke="#e24b4a" StrokeThickness="1" Fill="Transparent"/>
                                            <Rectangle Width="1.3" Height="3.5" Canvas.Left="6.35" Canvas.Top="3.5"
          Fill="#e24b4a" RadiusX="0.65" RadiusY="0.65"/>
                                            <Ellipse Width="1.4" Height="1.4" Canvas.Left="6.3" Canvas.Top="9.3"
          Fill="#e24b4a"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=EventDescriptionText}"
                              FontFamily="Segoe UI" FontSize="11.5"
                              Foreground="#a32d2d"
                              VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBox x:Name="EventDescriptionText"
                                       Text="{Binding Event.EventDescription,UpdateSourceTrigger=PropertyChanged}"
                                       FontSize="15"
                                       Foreground="#374151"
                                       TextWrapping="Wrap"
                                      IsReadOnly="True"
                                     Style="{StaticResource EditableTextBoxStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Attendees Section -->
                    <StackPanel Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#xE716;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="#8B5CF6"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Attendees"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Attendee List - replace ItemsControl binding with your ObservableCollection -->
                        <ItemsControl x:Name="AttendeesListControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AttendeeCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar circle -->
                                            <Border Grid.Column="0"
                                                    Width="44" Height="44"
                                                    CornerRadius="22">
                                                
                                                <Border.Clip>
                                                    <EllipseGeometry Center="22,22" RadiusX="22" RadiusY="22"/>
                                                </Border.Clip>
                                                <Image Stretch="UniformToFill" Source="{Binding ResidentImage,Converter={StaticResource urlConverter}}"></Image>
                                            
                                    </Border>

                                            <!-- Name & Role -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ResidentName}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="#111827"/>
                                                <TextBlock Text="AA"
                                                           FontSize="13"
                                                           Foreground="#94a3b8"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- RSVP Badge -->
                                            <Border Grid.Column="3"
                                                    CornerRadius="12"
                                                    Padding="10,4"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#D1FAE5" Offset="0"/>
                                                        <GradientStop Color="#A7F3D0" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="Going"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#065F46"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                      
                    </StackPanel>

                    <!-- Action Buttons -->
                    <Grid Margin="0,28,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Close"
                                Style="{StaticResource CloseButtonStyle}"
                                x:Name="CloseEvenDetailButton" Click="CloseEvenDetailButton_Click"/>

                        <Button Grid.Column="2"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="ButtonEditEvent_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Foreground="White"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="MainButton" Text="Edit Event" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>

</Window>