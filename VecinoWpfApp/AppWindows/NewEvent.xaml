<Window
    x:Class="VecinoWpfApp.AppWindows.NewEvent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:VecinoWpfApp.AppWindows"
    Title="Vecino – Create Event"
    Height="1000"
    Width="800"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Background="#F3F0FB"
    FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="boolToVisibility">
            
        </BooleanToVisibilityConverter>
        <!-- TextBox Style -->
        <Style x:Key="FormInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="16,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DatePicker Style -->
        <Style x:Key="FormDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="#f8fafc"
                                BorderBrush="#cbd5e1"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox"
                                                   Grid.Column="0"
                                                   Background="Transparent"
                                                   BorderThickness="0"
                                                   Foreground="#1e293b"
                                                   FontSize="15"
                                                   Margin="16,0,0,0"
                                                   VerticalAlignment="Center"/>
                                <Button x:Name="PART_Button"
                                        Grid.Column="1"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Focusable="False"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE787;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="16"
                                               Foreground="#64748b"/>
                                </Button>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       StaysOpen="False">
                                    <Calendar x:Name="PART_Calendar"/>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#1e293b"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="#f8fafc"
                                BorderBrush="#cbd5e1"
                                BorderThickness="1">
                            <Grid>
                                <ContentPresenter x:Name="ContentSite"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        Margin="16,12,40,12"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False"/>
                                <ToggleButton Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <TextBlock Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12"
                                                           Foreground="#64748b"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,16,0"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       StaysOpen="False">
                                    <Border Background="White"
                                            BorderBrush="#cbd5e1"
                                            BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="12" ShadowDepth="4" Direction="270"/>
                                        </Border.Effect>
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#8B5CF6" Offset="0"/>
                                    <GradientStop Color="#EC4899" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#8B5CF6" Opacity="0.3" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cancel Button -->
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Background" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f1f5f9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F3F0FB" Offset="0"/>
                <GradientStop Color="#FDF2F8" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="780"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Background="White"
                CornerRadius="16"
                Padding="52,44">
            <Border.Effect>
                <DropShadowEffect Color="#C4B5FD" BlurRadius="40" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <StackPanel Margin="0,0,0,32" HorizontalAlignment="Center">
                    <Border Width="60" Height="60" CornerRadius="30"
                            HorizontalAlignment="Center" Margin="0,0,0,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8B5CF6" Offset="0"/>
                                <GradientStop Color="#EC4899" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#xE787;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="26"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Add Event"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Schedule a new community event"
                               FontSize="14"
                               Foreground="#94a3b8"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Event Title" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent,ElementName=TitleInput}" Width="589" Margin="20 0 0 0"
                               Visibility="{Binding (Validation.HasError),Converter={StaticResource boolToVisibility},ElementName=TitleInput}"></TextBlock>
                </StackPanel>
               
                <TextBox x:Name="TitleInput"
                         Style="{StaticResource FormInputStyle}"
                         Margin="0,0,0,18"
                         Text="{Binding Event.EventTitle,UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Event Date" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="EventDatePicker"
                            Style="{StaticResource FormDatePickerStyle}"
                            Margin="0,0,0,18"/>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Start Time" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="StartTimeComboBox" Style="{StaticResource FormComboBoxStyle}">
                            <ComboBoxItem Content="Select" IsSelected="True"/>
                            <ComboBoxItem Content="8:00 AM"/>
                            <ComboBoxItem Content="9:00 AM"/>
                            <ComboBoxItem Content="10:00 AM"/>
                            <ComboBoxItem Content="11:00 AM"/>
                            <ComboBoxItem Content="12:00 PM"/>
                            <ComboBoxItem Content="1:00 PM"/>
                            <ComboBoxItem Content="2:00 PM"/>
                            <ComboBoxItem Content="3:00 PM"/>
                            <ComboBoxItem Content="4:00 PM"/>
                            <ComboBoxItem Content="5:00 PM"/>
                            <ComboBoxItem Content="6:00 PM"/>
                            <ComboBoxItem Content="7:00 PM"/>
                            <ComboBoxItem Content="8:00 PM"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="End Time" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="EndTimeComboBox" Style="{StaticResource FormComboBoxStyle}" >
                            <ComboBoxItem Content="Select" IsSelected="True"/>
                            <ComboBoxItem Content="9:00 AM"/>
                            <ComboBoxItem Content="10:00 AM"/>
                            <ComboBoxItem Content="11:00 AM"/>
                            <ComboBoxItem Content="12:00 PM"/>
                            <ComboBoxItem Content="1:00 PM"/>
                            <ComboBoxItem Content="2:00 PM"/>
                            <ComboBoxItem Content="3:00 PM"/>
                            <ComboBoxItem Content="4:00 PM"/>
                            <ComboBoxItem Content="5:00 PM"/>
                            <ComboBoxItem Content="6:00 PM"/>
                            <ComboBoxItem Content="7:00 PM"/>
                            <ComboBoxItem Content="8:00 PM"/>
                            <ComboBoxItem Content="9:00 PM"/>
                            <ComboBoxItem Content="10:00 PM"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>


                <TextBlock Text="Type" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="TypeComboBox"
                          Style="{StaticResource FormComboBoxStyle}"
                          Margin="0,0,0,18" SelectedValuePath="EventTypeId" DisplayMemberPath="EventTypeName">
                  
                </ComboBox>
                <Button Content="Upload Image" Click="ButtonSelectImage_Click"></Button>
        
                
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Description" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="{Binding (Validation.Errors)[0].ErrorContent,ElementName=DescriptionInput}" Width="589" Margin="20 0 0 0"
                Visibility="{Binding (Validation.HasError),Converter={StaticResource boolToVisibility},ElementName=DescriptionInput}"></TextBlock>
                </StackPanel>
                <Border Background="#f8fafc"
                        BorderBrush="#cbd5e1"
                        BorderThickness="1"
                        Margin="0,0,0,30">
                    
                    <TextBox x:Name="DescriptionInput"
                             Height="120"
                             Padding="16,12"
                             FontSize="15"
                             Foreground="#1e293b"
                             Background="Transparent"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             Text="{Binding Event.EventDescription,UpdateSourceTrigger=PropertyChanged}"
                             />
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Cancel"
                            Style="{StaticResource CancelButtonStyle}"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource PrimaryButtonStyle}" Click="ButtonAddEvent_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Add Event" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>

</Window>