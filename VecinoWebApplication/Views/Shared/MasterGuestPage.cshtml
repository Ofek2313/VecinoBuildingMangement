@{
    ViewData["Title"] = "MasterGuestPage";
    
}


<!DOCTYPE html>

<html>
<head>
    <meta charset="UTF-8"/>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* <link rel="stylesheet" href="~/css/guest.css"/> *@
    <title>Home Page</title>
    <link rel="stylesheet" href="~/css/guest.css"/>

</head>
<body>

    <nav class="navbar">

        <a href="http://localhost:5086/Guest/HomePage" class="nav-brand">
            <div class="brand-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
            </div>
            <div class="brand-text">
                <span class="brand-name">Vecino</span>
                <span class="brand-tagline">Building Management</span>
            </div>
        </a>

        <a href="http://localhost:5086/Guest/ViewBuildingCatalogue" class="nav-item">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            <span>Buildings</span>
        </a>

        @if (Context.Session.GetString("residentId") == null)
        {
            <div class="nav-divider" aria-hidden="true"></div>

            <a href="http://localhost:5086/Resident/LoginForm" class="nav-item nav-login">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                </svg>
                <span>Login</span>
            </a>

            <a href="http://localhost:5086/Guest/RegisterForm" class="nav-item nav-register">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                </svg>
                <span>Register</span>
            </a>
        }
        else
        {
            <a href="http://localhost:5086/Resident/JoinBuildingForm" class="nav-item nav-join">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 7v6m0 0v3m0-3h3m-3 0H9" />
                </svg>
                <span>Join Building</span>
            </a>
        }

    </nav>

    
   

    
    @RenderBody()

</body>
</html>
