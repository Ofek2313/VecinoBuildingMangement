@{
    ViewData["Title"] = "MasterGuestPage";
    
}


<!DOCTYPE html>

<html>
<head>
    <meta charset="UTF-8"/>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* <link rel="stylesheet" href="~/css/guest.css"/> *@
    <title>Home Page</title>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --teal: #14b8a6;
            --teal-dark: #0f9488;
            --blue: #3b82f6;
            --blue-dark: #1d4ed8;
            --slate: #1e293b;
            --muted: #64748b;
            --muted-light: #94a3b8;
            --border: rgba(226, 232, 240, 0.6);
            --surface: #f8fafc;
            --white: #ffffff;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--surface);
            color: var(--slate);
        }

        /* ─── Navbar — mirrors sidebar background/border/shadow ─── */
        .navbar {
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            background: linear-gradient(180deg, #ffffff 0%, #ffffff 70%, rgba(240, 253, 250, 0.3) 100%);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            height: 64px;
            position: relative;
            z-index: 10000;
            gap: 0.375rem;
        }

        /* ─── Brand ─── */
        .nav-brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            margin-right: auto;
            transition: opacity 0.2s;
        }

            .nav-brand:hover {
                opacity: 0.85;
            }

        .brand-icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--teal), var(--blue));
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 2px 8px rgba(20, 184, 166, 0.3);
        }

            .brand-icon svg {
                width: 17px;
                height: 17px;
                stroke: white;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

        .brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1;
        }

        .brand-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.25rem;
            font-weight: 500;
            background: linear-gradient(135deg, #1e293b, #0d9488);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: -0.01em;
        }

        .brand-tagline {
            font-size: 0.625rem;
            font-weight: 400;
            color: var(--muted-light);
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin-top: 2px;
        }

        /* ─── Divider ─── */
        .nav-divider {
            width: 1px;
            height: 22px;
            background: var(--border);
            margin: 0 0.5rem;
            flex-shrink: 0;
        }

        /* ─── Nav items — identical to sidebar .nav-item ─── */
        .nav-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0.875rem;
            border-radius: 0.75rem;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--muted);
            text-decoration: none;
            transition: all 0.2s;
            white-space: nowrap;
            cursor: pointer;
        }

            .nav-item:hover {
                background: linear-gradient(90deg, #f1f5f9, #dbeafe);
                color: var(--slate);
            }

            .nav-item svg {
                width: 1.1rem;
                height: 1.1rem;
                color: #94a3b8;
                transition: all 0.2s;
                flex-shrink: 0;
            }

            .nav-item:hover svg {
                transform: scale(1.1);
                color: var(--slate);
            }

            /* ─── Login ─── */
            .nav-item.nav-login {
                color: var(--blue);
                font-weight: 600;
            }

                .nav-item.nav-login:hover {
                    background: linear-gradient(90deg, #eff6ff, #dbeafe);
                    color: var(--blue-dark);
                }

                .nav-item.nav-login svg {
                    color: var(--blue);
                }

            /* ─── Register & Join Building — matches sidebar .nav-item.active ─── */
            .nav-item.nav-register,
            .nav-item.nav-join {
                background: linear-gradient(90deg, var(--teal), var(--blue));
                color: white;
                font-weight: 600;
                box-shadow: 0 4px 12px rgba(20, 184, 166, 0.3);
            }

                .nav-item.nav-register:hover,
                .nav-item.nav-join:hover {
                    opacity: 0.92;
                    box-shadow: 0 6px 16px rgba(20, 184, 166, 0.35);
                    transform: translateY(-1px);
                }

                .nav-item.nav-register:active,
                .nav-item.nav-join:active {
                    transform: scale(0.985);
                }

                .nav-item.nav-register svg,
                .nav-item.nav-join svg {
                    color: white;
                }
</style>
</head>
<body>

    <nav class="navbar">

        <a href="http://localhost:5086/Guest/HomePage" class="nav-brand">
            <div class="brand-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
            </div>
            <div class="brand-text">
                <span class="brand-name">Vecino</span>
                <span class="brand-tagline">Building Management</span>
            </div>
        </a>

        <a href="http://localhost:5086/Guest/ViewBuildingCatalogue" class="nav-item">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            <span>Buildings</span>
        </a>

        @if (Context.Session.GetString("residentId") == null)
        {
            <div class="nav-divider" aria-hidden="true"></div>

            <a href="http://localhost:5086/Resident/LoginForm" class="nav-item nav-login">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                </svg>
                <span>Login</span>
            </a>

            <a href="http://localhost:5086/Guest/RegisterForm" class="nav-item nav-register">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                </svg>
                <span>Register</span>
            </a>
        }
        else
        {
            <a href="http://localhost:5086/Resident/JoinBuildingForm" class="nav-item nav-join">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 7v6m0 0v3m0-3h3m-3 0H9" />
                </svg>
                <span>Join Building</span>
            </a>
        }

    </nav>

    
   

    
    @RenderBody()

</body>
</html>
