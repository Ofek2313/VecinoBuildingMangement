@using System.Text.Json
@using VecinoBuildingMangement.ViewModels
@using VecinoBuildingMangement.Models
@model BuildingCatalouge
@{
    ViewData["Title"] = "ViewBuildingCatalogue";
    Layout = "~/Views/Shared/MasterGuestPage.cshtml";
}

<link rel="stylesheet" href="~/css/Building.css">
<link rel="stylesheet" href="~/lib/leaflet/leaflet.css" />
<div class="page-wrapper">

    <header class="page-header">
        <h1>Building Catalogue</h1>
        <p>Manage and view your community's architecture.</p>
    </header>

<div class="stats-bar">
    <div class="stat-chip">
        <div class="stat-icon teal">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M9 3v18M15 3v18M3 9h18M3 15h18" /></svg>
        </div>
        <div class="stat-text">
            <span class="stat-value">6</span>
            <span class="stat-label">Total Buildings</span>
        </div>
    </div>
    <div class="stat-chip">
        <div class="stat-icon blue">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
        </div>
        <div class="stat-text">
            <span class="stat-value">356</span>
            <span class="stat-label">Total Units</span>
        </div>
    </div>
    <div class="stat-chip">
        <div class="stat-icon amber">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
        </div>
        <div class="stat-text">
            <span class="stat-value">5</span>
            <span class="stat-label">Cities</span>
        </div>
    </div>
</div>

<div class="buildings-grid" id="buildingsGrid">

    @foreach(Building building in Model.Buildings)
    {
        <div class="building-card">
            <div class="card-image" >
                    <img src=" @Url.Action("GetBuildingPhoto", "Guest", new { buildingId = building.BuildingId })" />
            </div>
            <div class="card-body">
                <div class="card-top">
                    <div class="building-name">Dizengoff Tower</div>
                    <div class="building-address">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                        @building.Address
                    </div>
                </div>
                <div class="card-divider"></div>
                <div class="card-stats">
                    <div class="card-stat">
                        <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                        <span class="card-stat-value">@building.TotalUnits</span>
                        <span class="card-stat-label">Units</span>
                    </div>
                    <div class="card-stat">
                        <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22" /><path d="M2 12h20M2 17h20M2 7h20" /></svg>
                        <span class="card-stat-value">@building.Floors</span>
                        <span class="card-stat-label">Floors</span>
                    </div>
                    <div class="card-stat">
                        <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 9h18M9 21V9" /></svg>
                        <span class="card-stat-value">4</span>
                        <span class="card-stat-label">Per floor</span>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <div class="city-tag"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" /></svg>Tel Aviv</div>
                <a href="#" class="view-link">View details <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg></a>
            </div>
        </div>
    }
   

    

    



   

</div>
  <div id="map" style="height:500px;"></div>
</div>
<script src="~/lib/leaflet/leaflet.js">

</script>
<script>
    var map = L.map('map').setView([31.5, 34.75], 7);

    var leafletIcon = L.icon ({iconUrl: '/lib/leaflet/images/building-solid-full.svg', iconSize:[32,32],iconAnchor: [16,32], popupAnchor: [0, -32]})
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png').addTo(map);

    const buildings = @Html.Raw(JsonSerializer.Serialize(Model.Buildings));
        buildings.forEach(building => {
        if (building.Latitude && building.Longitude) {
            L.marker([building.Latitude, building.Longitude],{icon:leafletIcon})
             .addTo(map)
                 .bindPopup(`
        <img src="/Guest/GetBuildingPhoto?buildingId=${building.BuildingId}"/>
        <div class="leaflet-popup-footer">
            <div class="popup-address">${building.Address}</div>
            <span class="popup-badge">Building</span>
        </div>
    `);

        }
    });
</script>
