@using System.Text.Json
@using VecinoBuildingMangement.ViewModels
@using VecinoBuildingMangement.Models
@model BuildingCatalouge
@{
    ViewData["Title"] = "ViewBuildingCatalogue";
    Layout = "~/Views/Shared/MasterGuestPage.cshtml";
}

@if (TempData["ErrorMessage"] != null)
{
    <script>
        alert("@TempData["ErrorMessage"]");
    </script>
}
<link rel="stylesheet" href="~/css/Building.css">
<link rel="stylesheet" href="~/lib/leaflet/leaflet.css" />
<div class="page-wrapper">

    <header class="page-header">
        <h1>Building Catalogue</h1>
        <p>Manage and view your community's architecture.</p>
    </header>

    <div class="stats-bar">
        <div class="stat-chip">
            <div class="stat-icon teal">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M9 3v18M15 3v18M3 9h18M3 15h18" /></svg>
            </div>
            <div class="stat-text">
                <span class="stat-value">6</span>
                <span class="stat-label">Total Buildings</span>
            </div>
        </div>
        <div class="stat-chip">
            <div class="stat-icon blue">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
            </div>
            <div class="stat-text">
                <span class="stat-value">356</span>
                <span class="stat-label">Total Units</span>
            </div>
        </div>
        <div class="stat-chip">
            <div class="stat-icon amber">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
            </div>
            <div class="stat-text">
                <span class="stat-value">5</span>
                <span class="stat-label">Cities</span>
            </div>
        </div>
    </div>

    <!-- Buildings Grid -->
    <div class="buildings-grid" id="buildingsGrid">
        @foreach (BuildingViewModel building in Model.Buildings)
        {
            <div class="building-card">
                <div class="card-image">
                    <img src="@Url.Action("GetBuildingPhoto", "Guest", new { buildingId = building.Building.BuildingId })" />
                </div>
                <div class="card-body">
                    <div class="card-top">
                        <div class="building-name">@building.Building.Address</div>
                        <div class="building-address">
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                            @building.CityName
                        </div>
                    </div>
                    <div class="card-divider"></div>
                    <div class="card-stats">
                        <div class="card-stat">
                            <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                            <span class="card-stat-value">@building.Building.TotalUnits</span>
                            <span class="card-stat-label">Units</span>
                        </div>
                        <div class="card-stat">
                            <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22" /><path d="M2 12h20M2 17h20M2 7h20" /></svg>
                            <span class="card-stat-value">@building.Building.Floors</span>
                            <span class="card-stat-label">Floors</span>
                        </div>
                        <div class="card-stat">
                            <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 9h18M9 21V9" /></svg>
                            <span class="card-stat-value">4</span>
                            <span class="card-stat-label">Per floor</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination — outside the grid -->
    <div class="pagination">
        @for (int i = 1; i <= Model.PageCount; i++)
        {
            <a href="/Guest/ViewBuildingCatalogue?page=@i"
               class="page-btn @(i == Model.Page ? "active" : "")">@i</a>
        }
    </div>

    <!-- Map Section -->
    <section class="map-section">
        <div class="map-section-header">
            <div class="map-header-left">
                <div class="map-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
                        <line x1="8" y1="2" x2="8" y2="18" />
                        <line x1="16" y1="6" x2="16" y2="22" />
                    </svg>
                </div>
                <div>
                    <h2 class="map-title">Community Map</h2>
                    <p class="map-subtitle">All buildings pinned across the region</p>
                </div>
            </div>
            
        </div>
        <div class="map-frame">
            <div id="map"></div>
        </div>
    </section>

</div>

<style>
    /* ── Pagination fix ── */
    .pagination {
        display: flex;
        gap: 6px;
        justify-content: center;
        margin-top: 2rem;
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
    }

    .page-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: #fff;
        color: #475569;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.15s ease;
    }

        .page-btn:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
            color: #1e293b;
        }

        .page-btn.active {
            background: linear-gradient(135deg, #14b8a6, #3b82f6);
            color: #fff;
            border-color: transparent;
            font-weight: 600;
            box-shadow: 0 2px 8px rgba(59,130,246,0.25);
        }

    /* ── Map Section ── */
    .map-section {
        margin-top: 3.5rem;
    }

    .map-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1rem;
        padding: 1.25rem 1.5rem;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 0.875rem 0.875rem 0 0;
        border-bottom: none;
    }

    .map-header-left {
        display: flex;
        align-items: center;
        gap: 0.875rem;
    }

    .map-icon {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 0.625rem;
        background: linear-gradient(135deg, #14b8a6, #3b82f6);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .map-icon svg {
            width: 1.25rem;
            height: 1.25rem;
            stroke: #ffffff;
        }

    .map-title {
        font-size: 1.05rem;
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 0.15rem;
    }

    .map-subtitle {
        font-size: 0.8rem;
        color: #94a3b8;
    }

    

        
    .map-frame {
        border: 1px solid #e2e8f0;
        border-radius: 0 0 0.875rem 0.875rem;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    }

        .map-frame #map {
            height: 500px;
            width: 100%;
        }
</style>

<script src="~/lib/leaflet/leaflet.js"></script>
<script>
    var map = L.map('map').setView([31.5, 34.75], 7);

    var leafletIcon = L.icon({
        iconUrl: '/lib/leaflet/images/building-solid-full.svg',
        iconSize: [32, 32],
        iconAnchor: [16, 32],
        popupAnchor: [0, -32]
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png').addTo(map);

    async function loadMap() {
        const res = await fetch(`http://localhost:5086/Guest/GetBuildingsMap`);
        const buildings = await res.json();

        buildings.forEach(b => {
            if (b.latitude && b.longitude) {
                L.marker([b.latitude, b.longitude], { icon: leafletIcon })
                    .addTo(map)
                    .bindPopup(`
                        <img src="/Guest/GetBuildingPhoto?buildingId=${b.buildingId}" />
                        <div class="leaflet-popup-footer">
                            <div class="popup-address">${b.address}</div>
                            <span class="popup-badge">Building</span>
                        </div>
                    `);
            }
        });
    }
    loadMap();
</script>
