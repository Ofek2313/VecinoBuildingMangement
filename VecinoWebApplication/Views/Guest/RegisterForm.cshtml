@using VecinoBuildingMangement.Models
@model Resident
@{
    ViewData["Title"] = "RegisterForm";
    Layout = "~/Views/Shared/MasterGuestPage.cshtml";
}
@if (TempData["ErrorMessage"] != null)
{
    <script>
        alert("@TempData["ErrorMessage"]");
    </script>
}
<link rel="stylesheet" href="~/css/Register.css"/>
<main class="page">
    <div class="card">
        <div class="card-top-bar"></div>

        <div class="card-header">
            <div class="brand">
                <div class="brand-icon">
                    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                </div>
                <div>
                    <div class="brand-name">Vecino</div>
                    <div class="brand-tagline">Building Management</div>
                </div>
            </div>
            <h1 class="header-title">Create account</h1>
            <p class="header-sub">Register to access your resident portal.</p>
        </div>

        <div class="card-body">
            <form asp-controller="Guest" asp-action="Register" method="post">

                <div class="field">
                    <label for="ResidentName">Full name</label>
                    <div class="input-wrap">
                        <svg class="input-icon" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                        <input type="text" id="ResidentName" placeholder="Full Name" asp-for="ResidentName" />
                    </div>
                    <span class="error-msg" asp-validation-for="ResidentName"></span>
                </div>

                <div class="field">
                    <label for="ResidentEmail">Email</label>
                    <div class="input-wrap">
                        <svg class="input-icon" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
                        <input type="email" id="ResidentEmail" placeholder="you@example.com" asp-for="ResidentEmail" />
                    </div>
                    <span class="error-msg" asp-validation-for="ResidentEmail"></span>
                </div>

                <div class="field">
                    <label for="ResidentPhone">Phone</label>
                    <div class="input-wrap">
                        <svg class="input-icon" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8 19.79 19.79 0 01.22 1.17 2 2 0 012.22 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" /></svg>
                        <input type="text" id="ResidentPhone" placeholder="050-000-0000" asp-for="ResidentPhone" />
                    </div>
                    <span class="error-msg" asp-validation-for="ResidentPhone"></span>
                </div>

                <div class="field">
                    <label for="ResidentPassword">Password</label>
                    <div class="input-wrap">
                        <svg class="input-icon" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0110 0v4" /></svg>
                        <input type="password" id="ResidentPassword" placeholder="••••••••" asp-for="ResidentPassword" />
                        <button type="button" class="pw-toggle" id="pwToggle" aria-label="Toggle password visibility">
                            <svg id="eyeIcon" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                        </button>
                    </div>
                    <span class="error-msg" asp-validation-for="ResidentPassword"></span>
                </div>

                <button type="submit" class="btn-submit">
                    <svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="22" y1="11" x2="16" y2="11" /></svg>
                    Create account
                </button>

                <div class="divider">or</div>

                <button type="reset" class="btn-ghost">
                    <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10" /><path d="M3.51 15a9 9 0 102.13-9.36L1 10" /></svg>
                    Clear form
                </button>

            </form>
        </div>

        <div class="card-footer">
            <p>Already have an account? <a asp-controller="Resident" asp-action="LogIn">Sign in here.</a></p>
        </div>
    </div>
</main>
