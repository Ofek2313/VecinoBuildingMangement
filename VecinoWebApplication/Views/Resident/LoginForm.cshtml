@using VecinoBuildingMangement.ViewModels;

@model LogInViewModel;



@{

    ViewData["Title"] = "LoginForm";

    Layout = "~/Views/Shared/MasterGuestPage.cshtml";

}











   

    <link  rel="stylesheet" href="~/css/Login.css"/>

    <main class="page">

        <div class="card">

            <div class="card-top-bar"></div>



            <div class="card-header">

                <div class="brand">

                    <div class="brand-icon">

                        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>

                    </div>

                    <div>

                        <div class="brand-name">Vecino</div>

                        <div class="brand-tagline">Building Management</div>

                    </div>

                </div>



                <h1 class="header-title">Welcome back</h1>

                <p class="header-sub">Sign in to access your resident dashboard.</p>

            </div>



            <div class="card-body">

                <form id="loginForm" asp-controller="Resident" asp-action="ResidentLogIn" method="post">



                    <div class="field" id="emailField">

                        <label for="email">Email or phone</label>

                        <div class="input-wrap">

                            <svg class="input-icon" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>

                            <input type="text" id="email" placeholder="you@example.com" autocomplete="email" asp-for="Email" />

                        </div>

                        <span class="error-msg">Please enter a valid email or phone number.</span>

                    </div>



                    <div class="field" id="passwordField">

                        <div class="field-row">

                            <label for="password">Password</label>

                            <a href="#" class="forgot">Forgot password?</a>

                        </div>

                        <div class="input-wrap">

                            <svg class="input-icon" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0110 0v4" /></svg>

                            <input type="password" id="password" placeholder="••••••••" autocomplete="current-password" asp-for="Password" />

                            <button type="button" class="pw-toggle" id="pwToggle" aria-label="Toggle password visibility">

                                <svg id="eyeIcon" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>

                            </button>

                        </div>

                        <span class="error-msg">Password is required.</span>

                    </div>



                    <div class="remember">

                        <input type="checkbox" id="remember" />

                        <span>Keep me signed in</span>

                    </div>



                    <button type="submit" class="btn-submit">

                        <svg viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4" /><polyline points="10 17 15 12 10 7" /><line x1="15" y1="12" x2="3" y2="12" /></svg>

                        Sign in

                    </button>



                    <div class="divider">or</div>

                    

                    <button type="button" class="btn-ghost">

                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" /></svg>

                        Browse as guest

                    </button>



                </form>

            </div>



            <div class="card-footer">

                <p>New resident? <a href="#">Request access from your building manager.</a></p>

            </div>

        </div>

    </main>



    <p class="page-footer">© 2025 Vecino Building Management</p>




