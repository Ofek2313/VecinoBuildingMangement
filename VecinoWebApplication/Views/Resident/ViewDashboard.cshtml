@using VecinoBuildingMangement.ViewModels
@using VecinoBuildingMangement.Models
@model MainpageViewModel
@{
    ViewData["Title"] = "ViewDashboard";
    ViewData["Active"] = "dashboard";
    Layout = "~/Views/Shared/MasterResidentPage.cshtml";
    var monthNames = new Dictionary<string, string>
    {
        { "1", "JAN" },
        { "2", "FEB" },
        { "3", "MAR" },
        { "4", "APR" },
        { "5", "MAY" },
        { "6", "JUN" },
        { "7", "JUL" },
        { "8", "AUG" },
        { "9", "SEP" },
        { "10", "OCT" },
        { "11", "NOV" },
        { "12", "DEC" }
    };
}


<link href="~/css/dashboard.css" rel="stylesheet" />
<div class="container">
   
    <div class="header">
        <div class="header-top">
            <div class="greeting">
                <h1>Welcome Back, @Context.Session.GetString("residentName")</h1>
                <p>Vecino Dashboard</p>
            </div>
            
        </div>

      
        <div class="personal-banner">
            <div class="banner-content">
                <div class="banner-label"></div>
                <div class="banner-title">@Model.Building.Address</div>
                <div class="banner-detail">Entrance Code: @Model.Building.EntranceCode</div>
            </div>
            <svg class="banner-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
        </div>
    </div>


    <div class="main-content">
       
        <div class="card systems-card">
            <div class="card-header">
                <h3 class="card-title">
                    <svg class="title-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    Upcoming Events
                </h3>
                <span class="event-count">@Model.events.Count Events</span>
            </div>

            <div class="events-list">
                @foreach(Event event1 in Model.events)
                {
                    <div class="event-item">
                        <div class="event-date">
                            <div class="event-day">@event1.EventDate.Split("/")[0]</div>
                            <div class="event-month">@monthNames[event1.EventDate.Split("/")[1]]</div>
                        </div>
                        <div class="event-details">
                            <div class="event-title">@event1.EventTitle</div>
                            <div class="event-info">
                                <svg class="event-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                3:00 PM - Rooftop
                            </div>
                        </div>
                    </div>
                }
                

                
            </div>
        </div>

      
        <div class="card notifications-card">
            <div class="card-header">
                <h3 class="card-title">
                    <svg class="title-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                    </svg>
                    Notifications
                </h3>
                <span class="notification-count">@Model.Notifications.Count</span>
            </div>

            <div class="notifications-list">
                @foreach(Notification notification in Model.Notifications)
                {
                    <div class="notification-item  @notification.Priority">
                        <div class="notification-header">
                            <div class="notification-title">
                                @if(notification.Priority == "Urgent")
                                {
                                    <svg class="notification-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                    </svg>
                                }
                                else if(notification.Priority == "Important")
                                {
                                    <svg class="notification-icon" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" fill="currentColor" stroke="none">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.553.553 0 0 1-1.1 0L7.1 4.995z" />
                                    </svg>
                                }
                                else
                                {
                                    <svg class="notification-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                                    </svg>
                                }

                                @notification.NotificationTitle
                                <span class="unread-indicator">New</span>
                            </div>
                            <span class="notification-time">1h ago</span>
                        </div>
                        <div class="notification-content">
                            @notification.NotificationMessage
                        </div>
                    </div>
                }
                

               

               


            </div>
        </div>
    </div>

   
</div>