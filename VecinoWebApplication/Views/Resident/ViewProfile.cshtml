@using VecinoBuildingMangement.Models
@model Resident
@{
    ViewData["Title"] = "ViewProfile";
    Layout = "~/Views/Shared/MasterResidentPage.cshtml";
}
<link  rel="stylesheet" href="~/css/profile.css"/>
@if (TempData["ErrorMessage"] != null)
{
    <script>
        alert("@TempData["ErrorMessage"]");
    </script>
}
<div class="container">
    <div class="header">
        <h1>My Profile</h1>
        <p>Manage your personal information and preferences</p>
    </div>

    <div class="profile-grid">
       
        <div class="card profile-card">
            <div class="profile-avatar" onclick="document.getElementById('photoInput').click()">
                <img src="@Url.Action("GetPhoto","Resident")" class="profile" />
                <button class="change-photo-btn">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Change Photo
                </button>
            </div>
            <form asp-action="UploadPhoto" asp-controller="Resident" method="post" enctype="multipart/form-data">
                <input name ="file" type="file" id="photoInput" accept="image/*" onchange="this.form.submit()">
            </form>

            <h2 class="profile-name">@Model.ResidentName</h2>
            <p class="profile-role">Resident • Apartment @Model.UnitNumber</p>
            

            
        </div>


        <div class="card">
            <h3 class="card-title">
                <svg class="title-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                Personal Information
            </h3>

            <div class="info-section">
                <div class="section-header">Contact Details</div>
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">Email Address</div>
                        <div class="info-value">
                            <svg class="info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            <p>@Model.ResidentEmail</a>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Phone Number</div>
                        <div class="info-value">
                            <svg class="info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                            @Model.ResidentPhone
                        </div>
                    </div>
                </div>
            </div>

            <div class="info-section">
                <div class="section-header">Apartment Details</div>
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">Apartment Number</div>
                        <div class="info-value">
                            <svg class="info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                            </svg>
                            @Model.UnitNumber
                        </div>
                    </div>
                   
                </div>
            </div>



            <div class="btn-group">
                <button class="btn btn-primary" id="btn-primary">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                    Edit Profile
                </button>
               
            </div>
        </div>
    </div>
</div>
<div id="overlay" class="overlay"></div>
<div id="popout" class="PopOut">
    <div class="popup-accent-bar"></div>
    <div class="popup-body">
        <div class="popup-header">
            <div class="popup-title">
                <div class="popup-title-icon">
                    <svg fill="none" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                </div>
                <div>
                    <h2>Update Profile</h2>
                    <p>Edit your personal information</p>
                </div>
            </div>
            <button class="popup-close" id="popup-close-btn">✕</button>
        </div>

        <form asp-controller="Resident" asp-action="UpdateProfile">
            <div class="popup-field">
                <label>Full Name</label>
                <div class="input-wrap">
                    <svg fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                    <input asp-for="ResidentName" placeholder="Phone" class="input" />
                </div>
                <div class="error-wrap">
                    <svg fill="none" viewBox="0 0 24 24" width="13" height="13" stroke="#dc2626">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span asp-validation-for="ResidentName" class="error-msg"></span>
                </div>
            </div>
            <div class="popup-field">
                <label>Email</label>
                <div class="input-wrap">
                    <svg fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                    <input asp-for="ResidentEmail" placeholder="Email" class="input" />
                </div>
                <div class="error-wrap">
                    <svg fill="none" viewBox="0 0 24 24" width="13" height="13" stroke="#dc2626">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span asp-validation-for="ResidentEmail" class="error-msg"></span>
                </div>
            </div>
            <div class="popup-field">
                <label>Phone Number</label>
                <div class="input-wrap">
                    <svg fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                    <input asp-for="ResidentPhone" placeholder="Phone" class="input" />
                </div>
                <div class="error-wrap">
                    <svg fill="none" viewBox="0 0 24 24" width="13" height="13" stroke="#dc2626">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span asp-validation-for="ResidentPhone" class="error-msg"></span>
                </div>
            </div>
            <div class="popup-field">
                <label>Unit Number</label>
                <div class="input-wrap">
                    <svg fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                    <input asp-for="UnitNumber" placeholder="Unit Number" class="input" />
                </div>
                <div class="error-wrap">
                    <svg fill="none" viewBox="0 0 24 24" width="13" height="13" stroke="#dc2626">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span asp-validation-for="UnitNumber" class="error-msg"></span>
                </div>
            </div>

            <div class="popup-footer">
                <button type="button" class="btn-cancel" id="popup-close-btn">Cancel</button>
                <button type="submit" class="sumbitbtn">
                    <svg fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
<script>
   
    
    const popout = document.getElementById('popout');
    const overlay = document.getElementById('overlay');
    const openbtn = document.getElementById('btn-primary');
    const closebtn = document.getElementById('popup-close-btn');
    openbtn.addEventListener('click',function()
    {
        popout.style.display = 'block';
        overlay.style.display = 'block';
    }

    );
    overlay.addEventListener('click', function()  {
        overlay.style.display = 'none';
        popout.style.display = 'none';
    });
    closebtn.addEventListener('click',function()
    {
        overlay.style.display = 'none';
        popout.style.display = 'none';
    });
</script>



   
  