@{
    ViewData["Title"] = "GetBookingPage";
    ViewData["Active"] = "booking";
    Layout = "~/Views/Shared/MasterResidentPage.cshtml";
}

@using VecinoBuildingMangement.Models;
@using VecinoBuildingMangement.ViewModels;
@using VecinoBuildingMangement;
@model BookingViewModel
@if (TempData["ErrorMessage"] != null)
{
    <script>
        alert("@TempData["ErrorMessage"]");
    </script>
}
<link rel="stylesheet" href="~/css/Booking.css"/>

<main class="main">
    <div class="page-header">
        <h1>Room Bookings</h1>
        <p>Reserve the community room in your building</p>
    </div>

    <!-- DATE NAV + ADD BUTTON -->
    <div class="booking-topbar">
        <div class="date-nav-group">
            <button class="dnav-btn" onclick="moveDateDown('@Model.SelectedDate')" title="Previous day">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <div class="dnav-divider"></div>
            <div class="dnav-center">
                <span class="dnav-day-tag" id="day-tag-label"></span>
                <span class="dnav-date-text">@Model.SelectedDate</span>
            </div>
            <div class="dnav-divider"></div>
            <button class="dnav-btn" onclick="moveDateUp('@Model.SelectedDate')" title="Next day">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>

        <button class="add-booking-btn" onclick="openDrawer()">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 5v14M5 12h14" />
            </svg>
            Add booking
        </button>
    </div>

    <div class="layout">

        <!-- SCHEDULE GRID: single Community Room column -->
        <div class="sched-card">
            <div class="sched-head">
                <div class="sh-col" style="background: var(--bg);">Time</div>
                <div class="sh-col">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                    Community Room
                </div>
            </div>

            <div id="sched-body">
                @for (int hour = 8; hour <= 23; hour++)
                {
                    string timeDisplay = $"{hour:D2}:00";
                    <div class="time-row">
                        <div class="time-cell">@timeDisplay</div>
                        <div class="slot" data-hour="@hour" data-room="CommunityRoom">
                            @foreach (Booking booking in Model.Bookings)
                            {
                                if (booking.BookingStatus == BookingStatus.CONFIRMED)
                                {
                                    int startHourInt = int.Parse(booking.StartTime.Split(':')[0]);
                                    int endHourInt = int.Parse(booking.EndTime.Split(':')[0]);
                                    if (startHourInt == hour)
                                    {
                                        int duration = endHourInt - startHourInt;
                                        string heightStyle = $"calc({duration} * 100% - 6px)";
                                        <div class="bk c-community" style="height: @heightStyle; z-index: 10;">
                                            <div class="bk-name"></div>
                                            <div class="bk-who">@booking.StartTime – @booking.EndTime</div>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- RIGHT SIDE PANELS -->
        <div class="side">

            <!-- MY BOOKINGS -->
            <div class="panel">
                <div class="panel-title">My Bookings</div>
                <div class="bk-list">
                    @if (Model.MyBookings != null && Model.MyBookings.Any())
                    {
                        @foreach (var b in Model.MyBookings)
                        {
                            string badgeClass = b.BookingStatus switch
                            {
                                BookingStatus.AWAITING_APPROVAL => "s-pending",
                                BookingStatus.REJECTED => "s-rejected",
                                BookingStatus.AWAITING_PAYMENT => "s-payment",
                                BookingStatus.CONFIRMED => "s-booked",
                                _ => "s-pending"
                            };

                            string badgeLabel = b.BookingStatus switch
                            {
                                BookingStatus.AWAITING_APPROVAL => "Awaiting approval",
                                BookingStatus.REJECTED => "Rejected",
                                BookingStatus.AWAITING_PAYMENT => "Awaiting payment",
                                BookingStatus.CONFIRMED => "Booked",
                                _ => "Pending"
                            };

                            <div class="bk-item">
                                <div class="bk-item-head">
                                    <span class="bk-item-room">Community Room</span>
                                    <span class="status-badge @badgeClass">@badgeLabel</span>
                                </div>
                                <div class="bk-item-meta">
                                    <span>@b.BookingDate</span>
                                    <span>·</span>
                                    <span>@b.StartTime – @b.EndTime</span>
                                </div>
                                <div class="button-container">
                                    @if (b.BookingStatus == BookingStatus.AWAITING_PAYMENT)
                                    {
                                        <button class="pay-btn" onclick="OpenPopUp(this)" data-id="@b.BookingId">Pay For Booking</button>
                                    }
                                    @if(b.BookingStatus != BookingStatus.REJECTED)
                                    {
                                        <form asp-controller="Resident" asp-action="CancelBooking" asp-route-bookingId="@b.BookingId" asp-route-date="@Model.SelectedDate" method="post">
                                            <button type="submit" class="cancel-btn">Cancel</button>
                                        </form>
                                       
                                    }
                                   
                                </div>
                               
                            </div>
                        }
                    }
                    else
                    {
                        <p style="font-size:13px; color:var(--text-muted);">No bookings yet.</p>
                    }
                </div>
            </div>

            <!-- STATUS LEGEND -->
            <div class="panel">
                <div class="panel-title">Status legend</div>
                <div class="legend">
                    <div class="leg-item"><div class="leg-dot" style="background:#fac775"></div>Awaiting approval</div>
                    <div class="leg-item"><div class="leg-dot" style="background:#f09595"></div>Rejected</div>
                    <div class="leg-item"><div class="leg-dot" style="background:#85b7eb"></div>Awaiting payment</div>
                    <div class="leg-item"><div class="leg-dot" style="background:#97c459"></div>Booked</div>
                </div>
            </div>

        </div>
    </div>
</main>
<div id="overlay" class="overlay">
    <div class="popout" id="popout">

        <div class="popout-header">
            <h2>💳 Payment Details</h2>
            <button class="popout-close" onclick="document.getElementById('overlay').style.display='none'">&#x2715;</button>
        </div>

        <div class="card-icons">
            <span class="card-icon">VISA</span>
            <span class="card-icon">MC</span>
            <span class="card-icon">AMEX</span>
        </div>
        <form asp-action="PayBooking" asp-controller="Resident" asp-route-date="@Model.SelectedDate">

            <input id="modal-booking-id" type="hidden" name="bookingId" />
            <div class="modal-field">
                <label>Cardholder Name</label>
                <input type="text" placeholder="John Smith" />
            </div>

            <div class="modal-field">
                <label>Card Number</label>
                <input type="text" placeholder="1234 5678 9012 3456" maxlength="19" />
            </div>

            <div class="modal-row">
                <div class="modal-field">
                    <label>Expiry Date</label>
                    <input type="text" placeholder="MM/YY" maxlength="5" />
                </div>
                <div class="modal-field">
                    <label>CVV</label>
                    <input type="password" placeholder="•••" maxlength="3" />
                </div>
            </div>

            <hr class="modal-divider" />

            <div class="modal-actions">
                <button class="modal-cancel" onclick="document.getElementById('overlay').style.display='none'">Cancel</button>
                <button class="modal-confirm" id="confirm-btn" type="submit">💳 Pay Now</button>
            </div>
        </form>

    </div>
</div>
<!-- OVERLAY -->
<div class="drawer-overlay" id="drawer-overlay" onclick="closeDrawer()"></div>

<!-- SLIDE-IN DRAWER -->
<div class="drawer" id="drawer">
    <div class="drawer-header">
        <div class="drawer-title">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            New booking
        </div>
        <button class="drawer-close" onclick="closeDrawer()">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>

    <form asp-action="CreateBooking" asp-controller="Resident" method="post">
        <div class="drawer-body">

            <div class="field">
                <label>Room</label>
                <input type="text" value="Community Room" disabled style="background:var(--bg);cursor:default;" />
            </div>

            <div class="field">
                <label>Date</label>
                <input type="date" asp-for="Booking.BookingDate" />
            </div>

            <div class="field">
                <label>From → To</label>
                <div class="time-pair">
                    <select asp-for="Booking.StartTime">
                        @for (int h = 8; h <= 21; h++)
                        {
                            <option value="@($"{h:D2}:00")">@($"{h:D2}:00")</option>
                        }
                    </select>
                    <select asp-for="Booking.EndTime">
                        @for (int h = 9; h <= 22; h++)
                        {
                            <option value="@($"{h:D2}:00")">@($"{h:D2}:00")</option>
                        }
                    </select>
                </div>
            </div>

            <div class="field">
                <label>Note <span style="font-weight:400;text-transform:none;letter-spacing:0;font-size:10px">(optional)</span></label>
                <input type="text" asp-for="Booking.BookingNote"/>
            </div>

            <button class="drawer-submit" type="submit">Confirm booking</button>
        </div>
    </form>
    
</div>

<script>
    function OpenPopUp(button) {
        const overlay = document.getElementById('overlay');
        const bookingId = button.getAttribute('data-id');
        document.getElementById('modal-booking-id').value = bookingId;
        overlay.style.display = 'flex';
        

    }
    function parseDate(dateString) {
        var parts = dateString.split('/');
        return new Date(parseInt(parts[2]), parseInt(parts[1]) - 1, parseInt(parts[0]));
    }

    function addDays(date, days) {
        var d = new Date(date);
        d.setDate(d.getDate() + days);
        return d;
    }

    function moveDateUp(stringDate) {
        var date = addDays(parseDate(stringDate), 1);
        window.location.href = '/Resident/GetBookingPage?date=' + date.toLocaleDateString('en-GB');
    }

    function moveDateDown(stringDate) {
        var date = addDays(parseDate(stringDate), -1);
        window.location.href = '/Resident/GetBookingPage?date=' + date.toLocaleDateString('en-GB');
    }

    function openDrawer() {
        document.getElementById('drawer').classList.add('open');
        document.getElementById('drawer-overlay').classList.add('open');
    }

    function closeDrawer() {
        document.getElementById('drawer').classList.remove('open');
        document.getElementById('drawer-overlay').classList.remove('open');
    }
</script>
