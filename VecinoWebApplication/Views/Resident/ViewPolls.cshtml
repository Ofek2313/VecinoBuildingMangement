@using VecinoBuildingMangement.Models
@using VecinoBuildingMangement.ViewModels
@using System.Globalization;
@model List<PollViewModel>

@{
    ViewData["Title"] = "ViewPolls";
    ViewData["Active"] = "polls";
    Layout = "~/Views/Shared/MasterResidentPage.cshtml";
}

<link rel="stylesheet" href="~/css/poll.css">
@if (TempData["ErrorMessage"] != null)
{
    <script>
        alert("@TempData["ErrorMessage"]");
    </script>
}
<div class="container">

    <div class="page-header">
        <div class="page-title-section">
            <h1>Community Polls</h1>
            <p>Have your say on community decisions</p>
        </div>
    </div>

    <!-- Filter Buttons -->
    <div class="filter-bar">
        <button class="filter-btn filter-btn--active" id="filter-all" onclick="filterAll()">All</button>
        <button class="filter-btn" id="filter-open" onclick="filterOpen()">Open</button>
        <button class="filter-btn" id="filter-closed" onclick="filterClose()">Closed</button>
    </div>

    <div class="polls-container">

        @foreach (PollViewModel poll in Model)
        {
            bool IsOpen = poll.poll.IsActive && DateTime.ParseExact(poll.poll.PollDate, "dd/MM/yyyy", CultureInfo.InvariantCulture) >= DateTime.Today;

            <div class="poll-card" id="" data-status="@(IsOpen ? "Active" : "Closed")">
                <div class="poll-header">
                    <div class="poll-icon active">
                        <svg width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M7 11h7v2H7zm0-4h10.97v2H7zm0 8h13v2H7zM4 4h2v16H4z" /></svg>
                    </div>
                    <div class="poll-info">
                        <div class="poll-title-row">
                            <h3 class="poll-title">@poll.poll.PollTitle</h3>
                            <span class="poll-badge active">@(IsOpen ? "Active" : "Closed")</span>
                        </div>
                        <p class="poll-description">@poll.poll.PollDescription</p>
                        <div class="poll-meta">
                            <span>
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                                </svg>
                                Amenities
                            </span>
                            <span>
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                @poll.poll.PollDate
                            </span>
                            <span>
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                                62 votes
                            </span>
                        </div>
                    </div>
                </div>

                <div class="poll-options" id="vote-@poll.poll.PollId" style="display:@(IsOpen && !poll.HasVoted ? "block" : "none");">
                    @foreach (OptionViewModel optionViewModel in poll.options)
                    {
                        <div class="poll-option" onclick="select(this,'@optionViewModel.option.OptionId','@optionViewModel.option.PollId')">
                            <div class="option-content">
                                <span data-optionid="@optionViewModel.option.OptionId" class="option-text">@optionViewModel.option.OptionText</span>
                            </div>
                        </div>
                    }
                    <button id="btn-vote" class="btn-submit-vote" onclick="vote(@poll.poll.PollId,this)">Vote</button>
                </div>

                <div class="poll-options" id="result-@poll.poll.PollId" style="display:@(!IsOpen || poll.HasVoted ? "block" : "none");">
                    @foreach (OptionViewModel optionViewModel in poll.options)
                    {
                        <div class="option-result">
                            <div class="option-progress" data-optionid="@optionViewModel.option.OptionId" style="width: @(optionViewModel.percentage)%;"></div>
                            <div class="poll-option">
                                <div class="option-content">
                                    <span class="option-name">@optionViewModel.option.OptionText</span>
                                    <span class="option-text" id="option-@optionViewModel.option.OptionId">@(optionViewModel.percentage)%</span>
                                </div>
                            </div>
                        </div>
                    }

                    @if (IsOpen)
                    {
                        <button id="btn-result-@poll.poll.PollId" class="btn-submit-vote" onclick="unVote(@poll.poll.PollId,this)">Change Vote</button>
                    }
                    else
                    {
                        <button class="btn-submit-vote" disabled>Voting Closed</button>
                    }
                </div>

            </div>
        }

    </div>
</div>

<style>
    
</style>

<script src="~/js/polls.js">

   
</script>
