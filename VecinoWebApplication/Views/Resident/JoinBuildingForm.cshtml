@{
    ViewData["Title"] = "JoinBuildingForm";
    Layout = "~/Views/Shared/MasterGuestPage.cshtml";
}
@using VecinoBuildingMangement.DTO
@using VecinoBuildingMangement.ViewModels;

@model JoinBuildingRequest;

@if (TempData["ErrorMessage"] != null)
{
    <script>
        alert("@TempData["ErrorMessage"]");
    </script>
}

<link rel="stylesheet" href="~/css/Login.css" />

<main class="page">
    <div class="card">
        <div class="card-top-bar"></div>

        <div class="card-header">
            <div class="brand">
                <div class="brand-icon">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                </div>
                <div>
                    <div class="brand-name">Vecino</div>
                    <div class="brand-tagline">Building Management</div>
                </div>
            </div>

            <h1 class="header-title">Join a building</h1>
            <p class="header-sub">Enter your building code and unit number to get started.</p>
        </div>

        <div class="card-body">
            <form asp-controller="Resident" asp-action="JoinBuilding" method="post">

                <div class="field">
                    <label for="buildingCode">Building code</label>
                    <div class="input-wrap">
                        <svg class="input-icon" viewBox="0 0 24 24">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0110 0v4" />
                        </svg>
                        <input type="text" id="buildingCode" name="buildingCode" placeholder="e.g. BLD-4821" autocomplete="off"  asp-for="BuildingCode"/>
                    </div>
                </div>

                <div class="field">
                    <label for="unitNumber">Unit number</label>
                    <div class="input-wrap">
                        <svg class="input-icon" viewBox="0 0 24 24">
                            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                        <input type="text" id="unitNumber" name="unitNumber" placeholder="e.g. 4B" autocomplete="off" asp-for="UnitNumber" />
                    </div>
                </div>

                <div style="margin-bottom: 1.5rem;"></div>

                <button type="submit" class="btn-submit">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                        <path d="M12 7v6m0 0v3m0-3h3m-3 0H9" />
                    </svg>
                    Join building
                </button>

                <div class="divider">or</div>

                <button type="reset" class="btn-ghost">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 12a9 9 0 1018 0 9 9 0 00-18 0" />
                        <path d="M3 12h4m10 0h4M12 3v4m0 10v4" />
                    </svg>
                    Clear fields
                </button>

            </form>
        </div>

        <div class="card-footer">
            <p>Don't have a code? <a href="#">Contact your building manager.</a></p>
        </div>
    </div>
</main>

<p class="page-footer">© 2025 Vecino Building Management</p>
